// Định vị góc xoay 3D chính xác để hiển thị kết quả xúc xắc
const faceRotations = {
    1: { x: 0, y: 0 },         // Mặt chính diện (Front)
    6: { x: 0, y: 180 },       // Mặt đằng sau (Back)
    2: { x: 0, y: -90 },       // Mặt bên phải (Right)
    5: { x: 0, y: 90 },        // Mặt bên trái (Left)
    3: { x: -90, y: 0 },       // Mặt bên trên (Top)
    4: { x: 90, y: 0 }         // Mặt bên dưới (Bottom)
};

// Khởi chạy hệ thống sau khi DOM tải xong
