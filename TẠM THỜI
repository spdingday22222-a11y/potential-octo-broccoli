// Định dạng tiền tệ VND
function formatCurrency(num) {
    return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".") + "đ";
}

// Cập nhật số dư người chơi
function updateBalanceUI() {
    document.getElementById("accountBalance").innerText = formatCurrency(balance);
}

// Nạp tiền ảo
function virtualDeposit() {
    balance += 2000000;
    updateBalanceUI();
}

// Rút tiền giả lập
function openWithdrawModal() {
    if (balance <= 0) {
        alert("Số dư không đủ để rút!");
        return;
    }
    alert(`Rút thành công ${formatCurrency(balance)} về tài khoản mô phỏng.`);
    balance = 0;
    updateBalanceUI();
    showLoseScreen();
}

// Xử lý chọn chip đặt cược
function selectChip(val, element) {
    document.querySelectorAll(".chip").forEach(c => c.classList.remove("selected"));
    element.classList.add("selected");
    currentChip = val;
}

// Lựa chọn vùng đặt cược (TÀI hoặc XỈU)
function handleSelectTarget(target) {
    selectedTarget = target;
    document.querySelectorAll(".bet-box").forEach(box => box.classList.remove("selected-target"));
    if (target === "TÀI") {
        document.getElementById("boxTai").classList.add("selected-target");
    } else {
        document.getElementById("boxXiu").classList.add("selected-target");
    }
}

// Hàm quy đổi giá trị chuỗi của Chip ra số nguyên thực tế
function getChipValue(chipStr) {
    switch (chipStr) {
        case "10K": return 10000;
        case "50K": return 50000;
        case "100K": return 100000;
        case "500K": return 500000;
        case "1M": return 1000000;
        default: return 10000;
    }
}

// Đặt cược trực tiếp thông qua nút bấm
function placeBetDirectly(target, event) {
    if (event) event.stopPropagation(); // Tránh kích hoạt lại sự kiện chọn box
    if (isPlaying) {
        alert("Đã khóa đặt cược! Hãy chờ ván mới.");
        return;
    }

    const betVal = getChipValue(currentChip);
    if (balance < betVal) {
        alert("Số dư của bạn không đủ!");
        if (balance <= 0) showLoseScreen();
        return;
    }

    balance -= betVal;
    currentBets[target] += betVal;
    updateBalanceUI();
    updatePlayerBetsUI();
}

// Tất tay (All-in)
function allInBet() {
    if (isPlaying) return;
    if (!selectedTarget) {
        alert("Vui lòng chọn TÀI hoặc XỈU trước khi bấm Tất Tay!");
        return;
    }
    if (balance <= 0) {
        alert("Số dư đã hết!");
        return;
    }
    currentBets[selectedTarget] += balance;
    balance = 0;
    updateBalanceUI();
    updatePlayerBetsUI();
}

// Hủy bỏ lượt cược hiện tại
function clearCurrentBet() {
    if (isPlaying) return;
    balance += (currentBets["TÀI"] + currentBets["XỈU"]);
    currentBets = { "TÀI": 0, "XỈU": 0 };
    updateBalanceUI();
    updatePlayerBetsUI();
}

// Cập nhật giao diện tiền cược cá nhân
function updatePlayerBetsUI() {
    document.getElementById("myBetTaiValue").innerText = "Cược: " + formatCurrency(currentBets["TÀI"]);
    document.getElementById("myBetXiuValue").innerText = "Cược: " + formatCurrency(currentBets["XỈU"]);
}

// Vòng lặp đếm ngược chính
function startRound() {
    isPlaying = false;
    countdownVal = 26;
    document.getElementById("status").innerText = "Đang đặt cược...";
    document.getElementById("countdown").innerText = countdownVal;
    document.getElementById("status").style.color = "#ffffff";
    
    // Tạo giả lập tỷ lệ ngẫu nhiên cho Tool AI
    generateAIAnalysis();

    // Đồng bộ lại trạng thái xúc xắc: cho nẩy nhẹ (bouncing)
    const dArea = document.getElementById("diceArea");
    dArea.classList.add("bouncing");
    document.querySelectorAll(".dice").forEach(d => {
        d.classList.remove("rolling");
        d.style.transition = "transform 0.8s cubic-bezier(0.25, 1.1, 0.4, 1.1)";
    });

    countdownTimer = setInterval(() => {
        countdownVal--;
        document.getElementById("countdown").innerText = countdownVal;
        
        // Cập nhật vòng tròn tiến trình
        updateProgressRing(countdownVal);

        // Giả lập lượng tiền cược hệ thống dao động tăng dần
        simulateSystemBets();

        if (countdownVal <= 5) {
            document.getElementById("countdown").classList.add("pulse-active");
            document.getElementById("status").innerText = "Sắp khóa cược!";
            document.getElementById("status").style.color = "#ff3333";
        }

        if (countdownVal <= 0) {
            clearInterval(countdownTimer);
            document.getElementById("countdown").classList.remove("pulse-active");
            executeRollPhase();
        }
    }, 1000);
}

// Cập nhật hoạt ảnh chạy cho vòng tròn SVG Neon
function updateProgressRing(val) {
    const circleBar = document.getElementById("bar");
    const r = circleBar.r.baseVal.value;
    const circumference = 2 * Math.PI * r; // ~754px
    const percentage = val / 26;
    const offset = circumference - (percentage * circumference);
    circleBar.style.strokeDashoffset = offset;
}

function resetProgressRing() {
    const circleBar = document.getElementById("bar");
    circleBar.style.strokeDashoffset = 0;
}

// Giả lập dòng tiền cược của các người chơi trực tuyến khác
function simulateSystemBets() {
    if (countdownVal > 0) {
        totalBetsPool["TÀI"] += Math.floor(Math.random() * 500 + 100) * 1000;
        totalBetsPool["XỈU"] += Math.floor(Math.random() * 500 + 100) * 1000;
        
        const taiNode = document.getElementById("totalBetTai");
        const xiuNode = document.getElementById("totalBetXiu");

        taiNode.innerText = "Tổng: " + formatCurrency(totalBetsPool["TÀI"]);
        xiuNode.innerText = "Tổng: " + formatCurrency(totalBetsPool["XỈU"]);

        taiNode.classList.add("number-pop");
        xiuNode.classList.add("number-pop");

        setTimeout(() => {
            taiNode.classList.remove("number-pop");
            xiuNode.classList.remove("number-pop");
        }, 150);
    }
}

// Giả lập dữ liệu Phân tích của Tool AI
function generateAIAnalysis() {
    const rateTai = Math.floor(Math.random() * 61) + 20; // 20% -> 80%
    const rateXiu = 100 - rateTai;
    document.getElementById("rateTai").innerText = rateTai + "%";
    document.getElementById("rateXiu").innerText = rateXiu + "%";
}

// BƯỚC KHÓA CƯỢC & XEM KẾT QUẢ XÚC XẮC
function executeRollPhase() {
    isPlaying = true;
    document.getElementById("status").innerText = "Đang lắc...";
    document.getElementById("status").style.color = "#ffd700";

    const dArea = document.getElementById("diceArea");
    dArea.classList.remove("bouncing"); // Ngắt chế độ đứng im nẩy nhẹ

    // Chạy hiệu ứng xoay 3D liên tục (rolling)
    document.querySelectorAll(".dice").forEach(d => {
        d.style.transition = "none";
        d.classList.add("rolling");
    });

    // Sau 3.5s xoay liên tục, trả ra kết quả điểm chuẩn xác
    setTimeout(() => {
        // Tạo ngẫu nhiên 3 mặt xúc xắc từ 1 đến 6
        const r1 = Math.floor(Math.random() * 6) + 1;
        const r2 = Math.floor(Math.random() * 6) + 1;
        const r3 = Math.floor(Math.random() * 6) + 1;
        
        const sumResult = r1 + r2 + r3;
        const gameVerdict = (sumResult >= 11) ? "TÀI" : "XỈU";

        // Tắt lớp phủ xoay liên tục
        document.querySelectorAll(".dice").forEach(d => {
            d.classList.remove("rolling");
        });

        // Áp góc xoay chính xác cho từng xúc xắc
        rotateDiceToFace("d1", r1);
        rotateDiceToFace("d2", r2);
        rotateDiceToFace("d3", r3);

        // Hiển thị kết quả điểm số sau khi chuyển động quay dừng hẳn
        setTimeout(() => {
            document.getElementById("status").innerText = `${gameVerdict} - ${sumResult} điểm`;
            resolveRoundPayout(gameVerdict, sumResult);
        }, 850);

    }, 3500);
}

// Áp dụng định vị góc xoay 3D chân thực của phiên bản cũ
function rotateDiceToFace(diceId, face) {
    const dNode = document.getElementById(diceId);
    const rotation = faceRotations[face];
    if (rotation) {
        dNode.style.transition = "transform 0.8s cubic-bezier(0.25, 1.1, 0.4, 1.1)";
        // Thêm góc xoay vòng lớn để tạo quán tính đảo mượt mà
        dNode.style.transform = `rotateX(${rotation.x + 720}deg) rotateY(${rotation.y + 720}deg) rotateZ(360deg)`;
    }
}

// Xử lý cộng tiền thưởng thắng hoặc dọn dẹp số dư
function resolveRoundPayout(winner, sum) {
    let winAmount = 0;
    if (winner === "TÀI") {
        winAmount = currentBets["TÀI"] * 2;
        document.getElementById("boxTai").classList.add("winning-flash");
    } else {
        winAmount = currentBets["XỈU"] * 2;
        document.getElementById("boxXiu").classList.add("winning-flash");
    }

    if (winAmount > 0) {
        balance += winAmount;
        updateBalanceUI();
        triggerWinAnimation(winAmount);
    }

    // Thiết lập thời gian nghỉ giữa các phiên trước khi khởi động phiên mới
    setTimeout(() => {
        document.getElementById("boxTai").classList.remove("winning-flash");
        document.getElementById("boxXiu").classList.remove("winning-flash");
        
        // Đưa quỹ cược về 0
        currentBets = { "TÀI": 0, "XỈU": 0 };
        totalBetsPool = { "TÀI": 0, "XỈU": 0 };
        updatePlayerBetsUI();

        // Kiểm tra xem người chơi còn tiền không
        if (balance <= 0) {
            showLoseScreen();
        } else {
            startRound();
        }
    }, 4500);
}

// Hoạt ảnh thông báo nhận thưởng động
function triggerWinAnimation(amount) {
    const animText = document.createElement("div");
    animText.className = "win-animate-text";
    animText.innerText = `+${formatCurrency(amount)}`;
    document.querySelector(".main-stage").appendChild(animText);

    setTimeout(() => {
        animText.remove();
    }, 6000);
}

