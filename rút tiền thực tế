document.getElementById('withdrawal-form').addEventListener('submit', async function(e) {
    e.preventDefault(); // Ngăn trang bị tải lại mặc định

    // 1. Lấy dữ liệu đầu vào từ người dùng
    const bankCode = document.getElementById('bank-code').value;
    const accountNumber = document.getElementById('account-number').value;
    const amount = parseInt(document.getElementById('amount').value);
    
    const btnSubmit = document.getElementById('btn-submit');
    const responseMsg = document.getElementById('response-msg');

    // Vô hiệu hóa nút để tránh gửi trùng lệnh (Double-Click)
    btnSubmit.disabled = true;
    responseMsg.classList.add('hidden');

    // 2. Chuẩn bị cấu trúc dữ liệu Payload thực tế để gửi lên Backend của bạn
    const transactionData = {
        bank_code: bankCode,
        account_number: accountNumber,
        amount: amount,
        currency: "VND",
        timestamp: new Date().getTime()
    };

    try {
        /* 
           3. LOGIC KẾT NỐI SANG SERVER THỰC TẾ (BẮT BUỘC DÙNG BACKEND)
           Thay thế đường dẫn 'https://api.yourdomain.com/v1/payout' bằng API thật của bạn.
           Server Backend của bạn sẽ nhận data này, chạy mã hóa JWT/HMAC, rồi gọi sang ngân hàng.
        */
        const response = await fetch('https://api.yourdomain.com/v1/payout', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer YOUR_SECURE_SERVER_TOKEN' // Token bảo mật của phiên làm việc
            },
            body: JSON.stringify(transactionData)
        });

        const result = await response.json();

        if (response.ok && result.status === "SUCCESS") {
            // Xử lý khi cổng ngân hàng báo chuyển khoản thành công thực tế
            responseMsg.className = "response-message success";
            responseMsg.innerText = `Rút tiền thành công! Mã giao dịch: ${result.transaction_id}`;
            
            // Cập nhật lại số dư hiển thị nếu cần
            document.getElementById('balance-display').innerText = result.new_balance + " VND";
        } else {
            // Trường hợp lỗi từ ngân hàng (Sai tài khoản, bảo trì, không đủ số dư...)
            responseMsg.className = "response-message error";
            responseMsg.innerText = `Lỗi: ${result.message || "Giao dịch bị từ chối."}`;
        }

    } catch (error) {
        // Xử lý lỗi mất kết nối mạng hoặc lỗi server sập
        responseMsg.className = "response-message error";
        responseMsg.innerText = "Lỗi kết nối đến cổng xử lý tự động. Vui lòng thử lại sau!";
    } finally {
        // Mở khóa nút bấm sau khi xử lý xong
        btnSubmit.disabled = false;
        responseMsg.classList.remove('hidden');
    }
});


