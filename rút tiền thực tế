* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

body {
    background: radial-gradient(circle, #111d13 0%, #070b08 100%);
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #e0e0e0;
}

.banker-container {
    background: linear-gradient(135deg, #1a291e 0%, #111a13 100%);
    border: 1px solid #2d4a34;
    border-radius: 24px;
    width: 450px;
    padding: 35px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6), inset 0 1px 2px rgba(255, 255, 255, 0.1);
}

/* Nâng cấp Logo Thương Hiệu */
.logo-section {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 25px;
}

.logo-icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #ffd700 0%, #b8860b 100%);
    border-radius: 16px;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 0 15px rgba(218, 165, 32, 0.4);
}

.gold-glow {
    font-size: 1.8rem;
    font-weight: 900;
    color: #0d140f;
    text-shadow: 0 1px 2px rgba(255,255,255,0.5);
}

.logo-text h2 {
    font-size: 1.4rem;
    letter-spacing: 3px;
    color: #ffd700;
}

.system-status {
    font-size: 0.75rem;
    color: #00ff66;
    letter-spacing: 1px;
    margin-top: 4px;
    animation: pulse 2s infinite;
}

.divider {
    border: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, #2d4a34, transparent);
    margin-bottom: 25px;
}

/* Bảng thông tin số dư */
.info-board {
    display: flex;
    gap: 15px;
    margin-bottom: 30px;
}

.info-card {
    flex: 1;
    background: rgba(0, 0, 0, 0.3);
    padding: 15px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
}

.info-card span {
    display: block;
    font-size: 0.75rem;
    color: #888;
    margin-bottom: 5px;
}

.info-card strong {
    font-size: 1.1rem;
    color: #fff;
}

#balance-display {
    color: #00ff66;
}

/* Form nhập liệu */
.payout-form .input-group {
    margin-bottom: 20px;
    text-align: left;
}

.input-group label {
    display: block;
    font-size: 0.85rem;
    color: #aaa;
    margin-bottom: 8px;
}

.input-group input, .input-group select {
    width: 100%;
    padding: 14px;
    background: #0d140f;
    border: 1px solid #2d4a34;
    border-radius: 10px;
    color: #fff;
    font-size: 1rem;
    outline: none;
    transition: all 0.3s ease;
}

.input-group input:focus, .input-group select:focus {
    border-color: #ffd700;
    box-shadow: 0 0 10px rgba(218, 165, 32, 0.2);
}

/* Nút bấm xử lý */
.btn-payout {
    width: 100%;
    padding: 16px;
    background: linear-gradient(135deg, #00ff66 0%, #00993d 100%);
    border: none;
    border-radius: 12px;
    color: #000;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    letter-spacing: 1px;
    transition: transform 0.1s ease, box-shadow 0.3s ease;
    display: flex;
    justify-content: center;
    align-items: center;
}

.btn-payout:hover {
    box-shadow: 0 0 20px rgba(0, 255, 102, 0.4);
}

.btn-payout:active {
    transform: scale(0.98);
}

/* Trạng thái thông báo */
.response-message {
    margin-top: 20px;
    padding: 12px;
    border-radius: 8px;
    font-size: 0.9rem;
    text-align: center;
}

.response-message.success { background: rgba(0, 255, 102, 0.15); color: #00ff66; border: 1px solid #00ff66; }
.response-message.error { background: rgba(255, 51, 51, 0.15); color: #ff3333; border: 1px solid #ff3333; }
.hidden { display: none !important; }

@keyframes pulse {
    0% { opacity: 0.6; }
    50% { opacity: 1; }
    100% { opacity: 0.6; }
}





