        let userBalance = 100000000;
        let currentSelectedChip = 10000;
        let playerBets = { tai: 0, xiu: 0 };
        let activeSide = null;

        function selectChip(element, value) {
            document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
            element.classList.add('selected');
            currentSelectedChip = value;
        }

        function selectBetSide(side) {
            document.querySelectorAll('.bet-box').forEach(b => b.classList.remove('selected-target'));
            const targetBox = document.querySelector(`.bet-box.${side}`);
            targetBox.classList.add('selected-target');
            
            if (userBalance >= currentSelectedChip) {
                userBalance -= currentSelectedChip;
                playerBets[side] += currentSelectedChip;
                document.getElementById('user-balance').innerText = userBalance.toLocaleString() + " đ";
                document.getElementById(`my-bet-${side}`).innerText = playerBets[side].toLocaleString();
            } else {
                alert("Số dư VIP không đủ thực hiện lệnh cược này!");
            }
        }

        // --- KHỞI TẠO KHÔNG GIAN 3D THREEJS CHO XÚC XẮC ---
        let scene, camera, renderer, diceMeshes = [];
        const container = document.getElementById('threejs-dice-container');

        function init3DWorld() {
            const width = container.clientWidth;
            const height = container.clientHeight;
            
            scene = new THREE.Scene();
            
            camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
            camera.position.set(0, 0, 300);

            renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
            renderer.setSize(width, height);
            renderer.setPixelRatio(window.devicePixelRatio);
            renderer.shadowMap.enabled = true;
            container.appendChild(renderer.domElement);

            const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambientLight);

            const pointLight = new THREE.PointLight(0xffffff, 1.2, 500);
            pointLight.position.set(50, 150, 100);
            pointLight.castShadow = true;
            scene.add(pointLight);
            
            const initialPositions = [
                new THREE.Vector3(-45, 15, 0),
                new THREE.Vector3(45, 15, 0),
                new THREE.Vector3(0, -45, 10)
            ];

            for (let i = 0; i < 3; i++) {
                const dice = createThreeJSDice();
                dice.position.copy(initialPositions[i]);
                scene.add(dice);
                diceMeshes.push(dice);
            }

            animateEngine();
        }

        function createThreeJSDice() {
            const size = 32;
            const geometry = new THREE.BoxGeometry(size, size, size);
            const materials = [];
            const dotConfigs = [
                [ [0.5, 0.5] ], // 1
                [ [0.25, 0.25], [0.75, 0.75] ], // 2
                [ [0.2, 0.2], [0.5, 0.5], [0.8, 0.8] ], // 3
                [ [0.25, 0.25], [0.25, 0.75], [0.75, 0.25], [0.75, 0.75] ], // 4
                [ [0.2, 0.2], [0.2, 0.8], [0.5, 0.5], [0.8, 0.2], [0.8, 0.8] ], // 5
                [ [0.25, 0.2], [0.25, 0.5], [0.25, 0.8], [0.75, 0.2], [0.75, 0.5], [0.75, 0.8] ] // 6
            ];

            for (let f = 1; f <= 6; f++) {
                const canvas = document.createElement('canvas');
                canvas.width = 128;
                canvas.height = 128;
                const ctx = canvas.getContext('2d');

                const grad = ctx.createRadialGradient(64, 64, 5, 64, 64, 90);
                grad.addColorStop(0, '#ff3b3b');
                grad.addColorStop(0.8, '#990000');
                grad.addColorStop(1, '#4a0000');
                ctx.fillStyle = grad;
                ctx.fillRect(0, 0, 128, 128);

                ctx.strokeStyle = 'rgba(255, 215, 0, 0.3)';
                ctx.lineWidth = 6;
                ctx.strokeRect(3, 3, 122, 122);

                ctx.fillStyle = (f === 1) ? '#ffcc00' : '#ffffff';
                dotConfigs[f - 1].forEach(pos => {
                    ctx.beginPath();
                    ctx.arc(pos[0] * 128, pos[1] * 128, (f === 1) ? 18 : 10, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.strokeStyle = 'rgba(0,0,0,0.6)';
                    ctx.lineWidth = 2;
                    ctx.stroke();
                });

                const texture = new THREE.CanvasTexture(canvas);
                materials.push(new THREE.MeshPhongMaterial({ map: texture, shininess: 120 }));
            }
            return new THREE.Mesh(geometry, materials);
        }

        const targetRotations = {
            1: { x: 0, y: 0, z: 0 },
            2: { x: 0, y: -Math.PI / 2, z: 0 },
            3: { x: -Math.PI / 2, y: 0, z: 0 },
            4: { x: Math.PI / 2, y: 0, z: 0 },
            5: { x: 0, y: Math.PI / 2, z: 0 },
            6: { x: Math.PI, y: 0, z: 0 }
        };

        let isRolling3D = false;

        function roll3DDice(results) {
            isRolling3D = true;
            let duration = 3000;
            let startTime = Date.now();

            function updatePhysics() {
                let elapsed = Date.now() - startTime;
                let progress = elapsed / duration;

                if (progress < 1) {
                    diceMeshes.forEach((dice, idx) => {
                        dice.rotation.x += 0.35 + idx * 0.05;
                        dice.rotation.y += 0.4 + idx * 0.05;
                        dice.rotation.z += 0.25;
                        dice.position.y += Math.sin(elapsed * 0.05 + idx) * 1.5;
                    });
                    requestAnimationFrame(updatePhysics);
                } else {
                    isRolling3D = false;
                    diceMeshes.forEach((dice, idx) => {
                        const face = results[idx];
                        const target = targetRotations[face];
                        dice.rotation.set(target.x, target.y, target.z);
                        dice.position.y = (idx === 2) ? -45 : 15;
                    });
                    triggerWinLoseLogic(results);
                }
            }
            updatePhysics();
        }

        function animateEngine() {
            requestAnimationFrame(animateEngine);
            renderer.render(scene, camera);
        }

        // Xử lý thắng thua & cộng tiền
        function triggerWinLoseLogic(results) {
            const sum = results.reduce((a, b) => a + b, 0);
            const finalResult = (sum >= 11) ? 'tai' : 'xiu';

            document.getElementById('status-display').innerText = `Kết quả: ${sum} - ${finalResult.toUpperCase()}`;
            
            const winningBox = document.querySelector(`.bet-box.${finalResult}`);
            winningBox.classList.add('winning-flash');

            let winAmount = playerBets[finalResult] * 2;
            if (winAmount > 0) {
                userBalance += winAmount;
                document.getElementById('user-balance').innerText = userBalance.toLocaleString() + " đ";
                
                let winEl = document.createElement('div');
                winEl.className = 'win-notification';
                winEl.innerText = `+${winAmount.toLocaleString()}đ`;
                winningBox.appendChild(winEl);
            }
        }

        // --- KẾT NỐI WEBSOCKET REAL-TIME DỮ LIỆU ---
        const ws = new WebSocket(window.WS_SERVER);

        ws.onmessage = (event) => {
            const data = JSON.parse(event.data);
            
            if (data.event === "tick") {
                document.getElementById('timer').innerText = data.timeLeft;
                document.getElementById('total-bet-xiu').innerText = data.botBets.xiu.toLocaleString();
                document.getElementById('total-bet-tai').innerText = data.botBets.tai.toLocaleString();
                
                // Giả lập cập nhật tỷ lệ AI VIP ngẫu nhiên theo luồng cược
                let total = data.botBets.xiu + data.botBets.tai;
                let taiRate = Math.round((data.botBets.tai / total) * 100);
                document.getElementById('ai-tai').innerText = `Tài ${taiRate}%`;
                document.getElementById('ai-xiu').innerText = `Xỉu ${100 - taiRate}%`;
                
                document.getElementById('status-display').innerText = "Vui Lòng Đặt Cược";
            } 
            else if (data.event === "roll") {
                document.getElementById('timer').innerText = "0";
                document.getElementById('status-display').innerText = "Hết Thời Gian - Đang Mở Bát...";
                roll3DDice(data.dice);
            } 
            else if (data.event === "new_round") {
                // Khởi động lại phiên mới, xóa sạch dữ liệu cũ
                document.querySelectorAll('.bet-box').forEach(b => {
                    b.classList.remove('winning-flash', 'selected-target');
                    const notification = b.querySelector('.win-notification');
                    if(notification) notification.remove();
                });
                playerBets = { tai: 0, xiu: 0 };
                document.getElementById('my-bet-tai').innerText = "0";
                document.getElementById('my-bet-xiu').innerText = "0";
                document.getElementById('status-display').innerText = "Vòng Mới Bắt Đầu";
            }
        };

        window.addEventListener('load', () => {
            init3DWorld();
        });
    </script>
