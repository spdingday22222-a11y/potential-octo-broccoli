const WebSocket = require('ws');
const wss = new WebSocket.Server({ port: 8080 });

console.log("Casino WebSocket Server đang chạy tại cổng 8080...");

let timeLeft = 26;
let currentResults = [1, 1, 1];
let isBettingPhase = true;

// Hàm cập nhật trạng thái phòng đấu mỗi giây một lần
setInterval(() => {
    if (timeLeft > 0) {
        timeLeft--;
        // Giả lập bot cược liên tục vào cả hai cửa để tăng tương tác thực tế
        let botXiuBet = Math.floor(Math.random() * 25000000);
        let botTaiBet = Math.floor(Math.random() * 25000000);

        broadcast({
            event: "tick",
            timeLeft: timeLeft,
            bettingAllowed: isBettingPhase,
            botBets: { xiu: botXiuBet, tai: botTaiBet }
        });
    } else {
        if (isBettingPhase) {
            // Chuyển sang giai đoạn mở bát
            isBettingPhase = false;
            timeLeft = 5; // Thời gian hiển thị kết quả lăn 3D
            currentResults = [
                Math.floor(Math.random() * 6) + 1,
                Math.floor(Math.random() * 6) + 1,
                Math.floor(Math.random() * 6) + 1
            ];
            broadcast({
                event: "roll",
                dice: currentResults,
                timeLeft: timeLeft
            });
        } else {
            // Khởi động phiên mới
            isBettingPhase = true;
            timeLeft = 26;
            broadcast({
                event: "new_round",
                timeLeft: timeLeft
            });
        }
    }
}, 1000);

function broadcast(data) {
    wss.clients.forEach(client => {
        if (client.readyState === WebSocket.OPEN) {
            client.send(JSON.stringify(data));
        }
    });
}



