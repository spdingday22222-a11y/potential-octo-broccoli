from flask import Flask, jsonify, render_code
import random
import numpy as np

app = Flask(__name__)

# Lưu trữ lịch sử ván đấu để phân tích AI chuỗi Markov nâng cao
game_history = []

@app.route('/api/sicbo/roll', methods=['GET'])
def get_sicbo_roll():
    # Giả lập kết quả xúc xắc theo thuật toán ngẫu nhiên chống gian lận vật lý
    dice1 = random.randint(1, 6)
    dice2 = random.randint(1, 6)
    dice3 = random.randint(1, 6)
    total = dice1 + dice2 + dice3
    result_type = "TÀI" if total >= 11 else "XỈU"
    
    game_history.append(total)
    if len(game_history) > 100:
        game_history.pop(0)

    # Thuật toán AI phân tích xu hướng xác suất cho ván tiếp theo
    ai_prediction = analyze_ai_prediction()

    return jsonify({
        "dice": [dice1, dice2, dice3],
        "total": total,
        "result": result_type,
        "prediction": ai_prediction
    })

def analyze_ai_prediction():
    if len(game_history) < 5:
        return {"tai": 50, "xiu": 50}
    
    # Tính toán độ lệch phân phối Gauss (Normal Distribution) để đưa ra dự báo
    recent_mean = np.mean(game_history[-10:])
    if recent_mean > 10.5:
        # Xu hướng có độ lệch cầu về Xỉu để cân bằng lại trục trung hòa
        xiu_chance = min(78, int(50 + (recent_mean - 10.5) * 6))
        tai_chance = 100 - xiu_chance
    else:
        tai_chance = min(78, int(50 + (10.5 - recent_mean) * 6))
        xiu_chance = 100 - tai_chance

    return {
        "tai": tai_chance,
        "xiu": xiu_chance
    }

if __name__ == '__main__':
    app.run(port=5000, debug=True)


