// --- LOGIC HỆ THỐNG RÚT TIỀN --- //
const bankerPanel = document.getElementById('banker-container');
const btnOpenGateway = document.getElementById('btn-open-gateway');
const withdrawScreen = document.getElementById('withdrawScreen');

function closeBankerPanel() {
    if (bankerPanel) {
        bankerPanel.classList.add('hidden');
    }
    if (withdrawScreen) {
        withdrawScreen.classList.remove('active');
    }
    if (btnOpenGateway) {
        btnOpenGateway.classList.remove('hidden');
    }
}

function openBankerPanel() {
    if (bankerPanel) {
        bankerPanel.classList.remove('hidden');
    }
    if (withdrawScreen) {
        withdrawScreen.classList.add('active');
    }
    if (btnOpenGateway) {
        btnOpenGateway.classList.add('hidden');
    }
}

window.closeBankerPanel = closeBankerPanel;
window.openBankerPanel = openBankerPanel;

