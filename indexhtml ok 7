            <span class="bet-title">TÀI</span>
            <span class="bet-desc">11 - 17 (1 ăn 1)</span>
            
            <div class="player-bet-logo-box">
                <span id="myBetTaiValue" class="player-bet-logo-value">0đ</span>
            </div>
            
            <span id="totalBetTai" class="bet-amount-status">Tổng: 0đ</span>
        </div>
