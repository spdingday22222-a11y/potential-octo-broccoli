/* --- RESET & NỀN TẢNG --- */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
    background-color: #0d0e12;
    color: #ffffff;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 20px;
}

/* --- CONTAINER CHÍNH --- */
.banker-container {
    position: relative;
    background-color: #16181f;
    border: 1px solid #2c2f3a;
    border-radius: 16px;
    width: 100%;
    max-width: 460px;
    padding: 32px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.6);
}

/* --- KHU VỰC THƯƠNG HIỆU --- */
.logo-section {
    display: flex;
    align-items: center;
    gap: 16px;
}

.logo-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, #d4af37, #aa7c11);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 24px;
    font-weight: 900;
    color: #000000;
}

.gold-glow {
    text-shadow: 0 0 10px rgba(255, 215, 0, 0.6);
}

.logo-text h2 {
    font-size: 18px;
    letter-spacing: 1px;
    color: #ffffff;
}

.system-status {
