.quick-amounts {
    display: flex;
    gap: 8px;
    margin-top: 5px;
}
.btn-quick {
    flex: 1;
    background: #2a1b38;
    border: 1px solid #663399;
    color: white;
    font-size: 11px;
    padding: 6px 0;
    border-radius: 5px;
    cursor: pointer;
    text-align: center;
    font-weight: bold;
}
.btn-quick:hover { background: #3c2653; border-color: #ff66cc; }

.withdraw-actions {
    display: flex;
    gap: 10px;
    margin-top: 10px;
}
.btn-submit-withdraw {
    flex: 2;
    background: linear-gradient(135deg, #d4af37 0%, #8a6f27 100%);
    border: none;
    color: #000;
    font-weight: 900;
    padding: 12px;
    border-radius: 8px;
    cursor: pointer;
    text-transform: uppercase;
}
.btn-submit-withdraw:active { transform: scale(0.98); }
.btn-close-withdraw {
    flex: 1;
    background: #333;
    border: none;
    color: #fff;
    font-weight: bold;
    padding: 12px;
    border-radius: 8px;
    cursor: pointer;
}
