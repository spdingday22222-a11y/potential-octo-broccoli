    <div class="betting-table">
        <div id="boxXiu" class="bet-box xiu" onclick="handleBetPlacement('XỈU')">
            <span class="bet-title">XỈU</span>
            <span class="bet-desc">4 - 10 (1 ăn 1)</span>
            
