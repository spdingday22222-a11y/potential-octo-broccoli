    <div class="control-btns">
        <div class="btn-action btn-cancel" onclick="cancelAllBets()">Hủy Cược</div>
        <div class="btn-action btn-allin" onclick="triggerAllIn()">All-In Tất Tay</div>
    </div>

    <div class="chip-container">
        <div class="chip selected" data-value="1K" onclick="selectChip(this, 1000)"></div>
        <div class="chip" data-value="10K" onclick="selectChip(this, 10000)"></div>
        <div class="chip" data-value="50K" onclick="selectChip(this, 50000)"></div>
        <div class="chip" data-value="100K" onclick="selectChip(this, 100000)"></div>
        <div class="chip" data-value="500K" onclick="selectChip(this, 500000)"></div>
        <div class="chip" data-value="1M" onclick="selectChip(this, 1000000)"></div>
        <div class="chip" data-value="200M" onclick="selectChip(this, 200000000)"></div>
        <div class="chip" data-value="500M" onclick="selectChip(this, 500000000)"></div>
    </div>

    <div id="loseScreen" class="overlay-screen screen-lose">
        <div class="lose-box">
            <div class="lose-title">YOU LOSE</div>
            <div class="lose-msg">Rất tiếc, may mắn sẽ đến vào lần sau!</div>
        </div>
    </div>

    <script>
        const bar = document.getElementById('bar');
        const countdownEl = document.getElementById('countdown');
        const statusEl = document.getElementById('status');
        const diceElements = [document.getElementById('d1'), document.getElementById('d2'), document.getElementById('d3')];
        const balanceEl = document.getElementById('accountBalance');
        const statusXiuEl = document.getElementById('totalBetXiu');
        const statusTaiEl = document.getElementById('totalBetTai');
        const rateTaiEl = document.getElementById('rateTai');
        const rateXiuEl = document.getElementById('rateXiu');
        const boxXiu = document.getElementById('boxXiu');
        const boxTai = document.getElementById('boxTai');

        const myBetXiuValueEl = document.getElementById('myBetXiuValue');
        const myBetTaiValueEl = document.getElementById('myBetTaiValue');

        let timeWait = 26;
        const circumference = 2 * Math.PI * 120;
        bar.style.strokeDasharray = circumference;

        const faceTransforms = {
            1: { x: 0,   y: 0 }, 2: { x: 0,   y: -90 }, 3: { x: -90, y: 0 },
            4: { x: 90,  y: 0 }, 5: { x: 0,   y: 90 },  6: { x: 180, y: 0 }
        };

        let userBalance = 2000000;
        let currentSelectedValue = 1000; 
        
        let totalXiuBet = 0;
        let totalTaiBet = 0;
        let displayXiuBet = 0; 
        let displayTaiBet = 0; 
        let myXiuBet = 0;
        let myTaiBet = 0;

        let isBettingAllowed = true;
        let finalResults = [1, 1, 1];
        let loopTimer = null;
        let botBetInterval = null;

        startNewGameSession();

        // CẢI TIẾN: Hàm nảy số thông minh, tự động tăng tốc dựa trên độ chênh lệch tiền thực tế
        function animateBetNumbers() {
            let hasChanged = false;

            if (displayXiuBet < totalXiuBet) {
                let diffXiu = totalXiuBet - displayXiuBet;
                // Nếu khoảng cách cực lớn (do chip 200M/500M), tăng mạnh bước nhảy (step)
                let stepXiu = Math.ceil(diffXiu * 0.25); 
                if (diffXiu > 10000000) stepXiu = Math.ceil(diffXiu * 0.4); // Tăng tốc tối đa khi lệch dữ dội
                
                displayXiuBet += stepXiu;
                if (displayXiuBet > totalXiuBet) displayXiuBet = totalXiuBet;
                statusXiuEl.innerText = `Tổng: ${displayXiuBet.toLocaleString('vi-VN')}đ`;
                hasChanged = true;
            }
            
            if (displayTaiBet < totalTaiBet) {
                let diffTai = totalTaiBet - displayTaiBet;
                let stepTai = Math.ceil(diffTai * 0.25);
                if (diffTai > 10000000) stepTai = Math.ceil(diffTai * 0.4); 
                
                displayTaiBet += stepTai;
                if (displayTaiBet > totalTaiBet) displayTaiBet = totalTaiBet;
                statusTaiEl.innerText = `Tổng: ${displayTaiBet.toLocaleString('vi-VN')}đ`;
                hasChanged = true;
            }

            // Luôn duy trì chạy mượt mà kể cả khi phiên nhận cược kết thúc cho đến khi hiển thị đủ số tiền thực
            if (isBettingAllowed || displayXiuBet < totalXiuBet || displayTaiBet < totalTaiBet) {
                requestAnimationFrame(animateBetNumbers);
            }
        }

        function updateBalanceDisplay() {
            balanceEl.innerText = userBalance.toLocaleString('vi-VN') + 'đ';
        }

        function virtualDeposit() {
            userBalance += 2000000;
            updateBalanceDisplay();
        }

        function selectChip(element, value) {
            document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
            element.classList.add('selected');
            currentSelectedValue = value;
        }

        function preCalculateAndAnalyze() {
            finalResults = [
                Math.floor(Math.random() * 6) + 1,
                Math.floor(Math.random() * 6) + 1,
                Math.floor(Math.random() * 6) + 1
            ];
            const sum = finalResults[0] + finalResults[1] + finalResults[2];
            const resultText = (sum >= 11 && sum <= 17) ? "TÀI" : "XỈU";

            if (resultText === "TÀI") {
                rateTaiEl.innerText = "100%";
                rateXiuEl.innerText = "0%";
            } else {
                rateTaiEl.innerText = "0%";
                rateXiuEl.innerText = "100%";
            }
        }

        function startNewGameSession() {
            timeWait = 26;
            totalXiuBet = 0; totalTaiBet = 0;
            displayXiuBet = 0; displayTaiBet = 0;
            myXiuBet = 0; myTaiBet = 0;
            isBettingAllowed = true;

            preCalculateAndAnalyze();

            statusXiuEl.innerText = 'Tổng: 0đ';
            statusTaiEl.innerText = 'Tổng: 0đ';
            myBetXiuValueEl.innerText = '0đ';
            myBetTaiValueEl.innerText = '0đ';
            
            statusXiuEl.className = "bet-amount-status";
            statusTaiEl.className = "bet-amount-status";
            boxXiu.classList.remove('winning-flash');
            boxTai.classList.remove('winning-flash');

            document.getElementById('loseScreen').classList.remove('active');

            countdownEl.innerText = timeWait;
            statusEl.innerText = "Đang nhận cược...";
            bar.style.transition = 'none';
            bar.style.strokeDashoffset = 0;
            
            diceElements.forEach(d => {
                d.classList.remove('rolling');
                d.style.transform = `rotateX(0deg) rotateY(0deg)`;
            });

            updateBalanceDisplay();

            clearInterval(loopTimer);
            loopTimer = setInterval(() => {
                timeWait--;
                if (timeWait >= 0) {
                    countdownEl.innerText = timeWait;
                    let offset = circumference - (timeWait / 26) * circumference;
                    bar.style.transition = 'stroke-dashoffset 1s linear';
                    bar.style.strokeDashoffset = offset;
                }
                if (timeWait <= 0) {
                    clearInterval(loopTimer);
                    clearInterval(botBetInterval); 
                    isBettingAllowed = false; // Ngắt đặt cược trước khi xoay
                    startRollingAnimation();
                }
            }, 1000);

            startBotBettingSimulation();
            requestAnimationFrame(animateBetNumbers); 
        }

        function startBotBettingSimulation() {
            clearInterval(botBetInterval);
            botBetInterval = setInterval(() => {
                if (!isBettingAllowed || timeWait <= 1) return;

                const isXiu = Math.random() > 0.5;
                const chipValues = [50000, 100000, 500000, 1000000, 200000000, 500000000];
                const botBetAmount = chipValues[Math.floor(Math.random() * chipValues.length)] * (Math.floor(Math.random() * 2) + 1);

                if (isXiu) {
                    totalXiuBet += botBetAmount;
                } else {
                    totalTaiBet += botBetAmount;
                }
            }, 120); 
        }

        function handleBetPlacement(target) {
            if (!isBettingAllowed) return;

            if (userBalance < currentSelectedValue) {
                alert("Số dư không đủ để đặt cược chip này!");
                return;
            }

            userBalance -= currentSelectedValue;
            updateBalanceDisplay();

            if (target === 'XỈU') {
                myXiuBet += currentSelectedValue;
                totalXiuBet += currentSelectedValue;
                myBetXiuValueEl.innerText = myXiuBet.toLocaleString('vi-VN') + 'đ';
            } else {
                myTaiBet += currentSelectedValue;
                totalTaiBet += currentSelectedValue;
                myBetTaiValueEl.innerText = myTaiBet.toLocaleString('vi-VN') + 'đ';
            }
        }

        function cancelAllBets() {
            if (!isBettingAllowed) return;
            userBalance += (myXiuBet + myTaiBet);
            totalXiuBet -= myXiuBet;
            totalTaiBet -= myTaiBet;
            myXiuBet = 0;
            myTaiBet = 0;
            updateBalanceDisplay();
            myBetXiuValueEl.innerText = '0đ';
            myBetTaiValueEl.innerText = '0đ';
        }

        function triggerAllIn() {
            if (!isBettingAllowed || userBalance <= 0) return;
            const half = Math.floor(userBalance / 2);
            
            myXiuBet += half;
            totalXiuBet += half;
            myBetXiuValueEl.innerText = myXiuBet.toLocaleString('vi-VN') + 'đ';

            const remain = userBalance - half;
            myTaiBet += remain;
            totalTaiBet += remain;
            myBetTaiValueEl.innerText = myTaiBet.toLocaleString('vi-VN') + 'đ';

            userBalance = 0;
            updateBalanceDisplay();
        }

        function startRollingAnimation() {
            statusEl.innerText = "Đang lắc xúc xắc...";
            diceElements.forEach(d => d.classList.add('rolling'));

            setTimeout(() => {
                diceElements.forEach(d => d.classList.remove('rolling'));
                stopDiceAtResult();
            }, 4000);
        }

        function stopDiceAtResult() {
            for (let i = 0; i < 3; i++) {
                const res = finalResults[i];
                const trans = faceTransforms[res];
                
                let extraX = 720; 
                let extraY = 720;
                if (i === 1) { extraX = 1080; extraY = 360; }
                if (i === 2) { extraX = 360;  extraY = 1080; }

                diceElements[i].style.transform = `rotateX(${trans.x + extraX}deg) rotateY(${trans.y + extraY}deg)`;
            }

            setTimeout(() => {
                evaluateGameResult();
            }, 1000);
        }

        function evaluateGameResult() {
            const sum = finalResults[0] + finalResults[1] + finalResults[2];
            const resultText = (sum >= 11 && sum <= 17) ? "TÀI" : "XỈU";
            statusEl.innerText = `Kết quả: ${sum} - ${resultText}`;

            let wonAmount = 0;
            if (resultText === "TÀI") {
                boxTai.classList.add('winning-flash');
                statusTaiEl.className = "bet-amount-status winning-flash";
                if (myTaiBet > 0) {
                    wonAmount = myTaiBet * 2;
                    userBalance += wonAmount;
                    spawnWinAmountAnimation(boxTai, `+${wonAmount.toLocaleString('vi-VN')}đ`);
                }
            } else {
                boxXiu.classList.add('winning-flash');
                statusXiuEl.className = "bet-amount-status winning-flash";
                if (myXiuBet > 0) {
                    wonAmount = myXiuBet * 2;
                    userBalance += wonAmount;
                    spawnWinAmountAnimation(boxXiu, `+${wonAmount.toLocaleString('vi-VN')}đ`);
                }
            }

            updateBalanceDisplay();

            if ((myXiuBet > 0 || myTaiBet > 0) && wonAmount === 0) {
                document.getElementById('loseScreen').classList.add('active');
            }

            setTimeout(() => {
                startNewGameSession();
            }, 8000);
        }

        function spawnWinAmountAnimation(targetBox, text) {
            const winTextEl = document.createElement('div');
            winTextEl.className = 'win-animate-text';
            winTextEl.innerText = text;
            targetBox.appendChild(winTextEl);

            setTimeout(() => {
                winTextEl.remove();
            }, 7000);
        }
    </script>

