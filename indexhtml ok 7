    <script>
        let currentBalance = 25500000;

        const form = document.getElementById('withdrawal-form');
        const balanceDisplay = document.getElementById('balance-display');
        const amountInput = document.getElementById('amount');
        const bankSelect = document.getElementById('bank-code');
        const accountInput = document.getElementById('account-number');
        const btnSubmit = document.getElementById('btn-submit');
        const btnText = btnSubmit.querySelector('.btn-text');
        const spinner = btnSubmit.querySelector('.spinner');
        const responseMsg = document.getElementById('response-msg');

        function formatMoney(amount) {
            return amount.toLocaleString('en-US') + ' VND';
        }

        balanceDisplay.textContent = formatMoney(currentBalance);

        form.addEventListener('submit', function (e) {
            e.preventDefault();

            const withdrawValue = parseInt(amountInput.value, 10);
            const selectedBankName = bankSelect.options[bankSelect.selectedIndex].text;
            const targetAccount = accountInput.value.trim();

            if (withdrawValue > currentBalance) {
                showNotification('Giao dịch thất bại: Số dư khả dụng trong tài khoản không đủ.', 'error');
                return;
            }

            toggleLoading(true);

            setTimeout(() => {
                currentBalance -= withdrawValue;
                balanceDisplay.textContent = formatMoney(currentBalance);
                showNotification(`Lệnh rút tiền thành công! Đã chuyển khoản ${formatMoney(withdrawValue)} tới STK ${targetAccount} (${selectedBankName}).`, 'success');
                form.reset();
                toggleLoading(false);
            }, 2000);
        });

        function toggleLoading(isLoading) {
            if (isLoading) {
                btnSubmit.disabled = true;
                btnText.textContent = 'HỆ THỐNG ĐANG XỬ LÝ LỆNH...';
                spinner.classList.remove('hidden');
                responseMsg.classList.add('hidden');
            } else {
                btnSubmit.disabled = false;
                btnText.textContent = 'XÁC NHẬN RÚT TIỀN TỰ ĐỘNG';
                spinner.classList.add('hidden');
            }
        }

        function showNotification(text, statusType) {
            responseMsg.textContent = text;
            responseMsg.className = `response-message ${statusType}`;
        }

        function closeBankerPanel() {
            const panel = document.getElementById('withdrawScreen');
            const reopenButton = document.getElementById('btn-open-gateway');
            if (panel) {
                panel.classList.remove('active');
            }
            if (reopenButton) {
                reopenButton.classList.remove('hidden');
            }
        }

        function openBankerPanel() {
            const panel = document.getElementById('withdrawScreen');
            const reopenButton = document.getElementById('btn-open-gateway');
            if (panel) {
                panel.classList.add('active');
            }
            if (reopenButton) {
                reopenButton.classList.add('hidden');
            }
        }
    </script>
