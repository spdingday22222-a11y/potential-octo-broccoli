<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sic Bo Premium Casino - Hệ Thống Vận Hành Tự Động Toàn Diện</title>
    <style>
        :root {
            --dice-size: 54px;
            --dice-color: #d11a1a; 
            --dot-color: #111111; 
            --gold-grad: linear-gradient(135deg, #ffe066 0%, #f3a516 50%, #c1840b 100%);
            --metal-border: linear-gradient(to right, #bf953f, #fcf6ba, #b38728, #fbf5b7, #aa771c);
        }

        body {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            background: linear-gradient(125deg, #090114, #18011c, #000000, #22012d);
            background-size: 400% 400%;
            animation: gradientBackground 15s ease infinite;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            overflow: hidden;
            user-select: none;
        }

        @keyframes gradientBackground {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* --- THANH SỐ DƯ --- */
        .top-navigation {
            position: absolute;
            top: 15px;
            right: 20px;
            display: flex;
            gap: 12px;
            align-items: center;
            z-index: 10;
        }
        .header-bar {
            display: flex;
            align-items: center;
            background: rgba(0, 0, 0, 0.85);
            padding: 8px 16px;
            border-radius: 20px;
            border: 1px solid #d4af37;
            box-shadow: 0 4px 10px rgba(0,0,0,0.6);
        }
        .balance-label {
            color: #a3c2a6;
            font-size: 12px;
            font-weight: bold;
            margin-right: 8px;
            text-transform: uppercase;
        }
        .balance-amount {
            color: #00ff88;
            font-size: 16px;
            font-weight: bold;
            text-shadow: 0 0 6px rgba(0,255,136,0.4);
        }
        .btn-deposit {
            background: linear-gradient(135deg, #00b359 0%, #006633 100%);
            border: 1px solid #00ff88;
            padding: 8px 14px;
            color: #ffffff;
            font-size: 11px;
            font-weight: bold;
            border-radius: 20px;
            cursor: pointer;
            text-transform: uppercase;
            box-shadow: 0 4px 10px rgba(0,0,0,0.4);
            transition: all 0.2s ease;
        }
        .btn-withdraw {
            background: linear-gradient(135deg, #444 0%, #222 100%);
            border: 1px solid #666;
            padding: 8px 14px;
            color: #ffffff;
            font-size: 11px;
            font-weight: bold;
            border-radius: 20px;
            cursor: pointer;
            text-transform: uppercase;
            box-shadow: 0 4px 10px rgba(0,0,0,0.4);
            transition: all 0.2s ease;
        }

        /* --- LOGO NÂNG CẤP HOÀNG GIA 3D --- */
        .casino-logo-container {
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            margin-bottom: -15px;
            margin-top: 65px;
            z-index: 10;
        }
        .casino-logo {
            font-size: 32px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 6px;
            background: linear-gradient(135deg, #ffe066 0%, #f3a516 30%, #fff 50%, #f3a516 70%, #c1840b 100%);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0px 4px 10px rgba(0, 0, 0, 0.9)) drop-shadow(0px 0px 30px rgba(243, 165, 22, 0.3));
            padding-bottom: 5px;
            text-align: center;
            position: relative;
            animation: logoShine 3s linear infinite;
        }
        @keyframes logoShine {
            0% { background-position: 0% center; }
            100% { background-position: 200% center; }
        }
        .casino-logo::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 10%;
            width: 80%;
            height: 3px;
            background: var(--metal-border);
            box-shadow: 0 1px 5px rgba(0,0,0,0.5);
        }
        .casino-logo span {
            display: block;
            font-size: 11px;
            letter-spacing: 8px;
            color: #ffffff;
            margin-top: 8px;
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.8);
            font-weight: bold;
        }

        /* --- GIAO DIỆN SÂN KHẤU TRUNG TÂM --- */
        .main-stage {
            position: relative;
            width: 650px;
            height: 300px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* Vòng tròn neon giảm bớt độ chói (êm dịu tinh tế) */
        .progress-ring {
            position: absolute;
            transform: rotate(-90deg);
            z-index: 1;
            transition: transform 0.2s ease;
        }
        .progress-ring__circle {
            stroke: rgba(20, 10, 30, 0.8);
            stroke-width: 10;
            fill: rgba(3, 1, 8, 0.85);
            backdrop-filter: blur(12px);
            box-shadow: inset 0 0 30px rgba(0,0,0,0.9);
        }
        .progress-ring__bar {
            stroke-width: 8;
            fill: transparent;
            stroke-dasharray: 754;
            stroke-dashoffset: 0;
            stroke-linecap: round;
            stroke: url(#neonGradient);
            filter: drop-shadow(0 0 6px rgba(255, 26, 140, 0.4)) drop-shadow(0 0 2px rgba(255, 234, 0, 0.3));
            transition: stroke-dashoffset 1s linear;
        }

        @keyframes pulseTime {
            0% { transform: scale(1); filter: drop-shadow(0 0 5px rgba(255,26,140,0.4)); }
            50% { transform: scale(1.04); filter: drop-shadow(0 0 15px rgba(255, 0, 85, 0.7)); }
            100% { transform: scale(1); filter: drop-shadow(0 0 5px rgba(255,26,140,0.4)); }
        }
        .pulse-active {
            animation: pulseTime 0.6s ease-in-out infinite !important;
        }

        .status-text {
            position: absolute;
            top: 5px;
            color: #ffffff;
            font-size: 18px;
            text-transform: uppercase;
            letter-spacing: 2px;
            width: 100vw;
            text-align: center;
            font-weight: bold;
            text-shadow: 0 2px 5px rgba(0,0,0,0.9);
        }

        .countdown-number {
            position: absolute;
            font-size: 65px;
            color: rgba(255, 255, 255, 0.45);
            font-weight: 900;
            z-index: 2;
            text-shadow: 0 0 10px rgba(255, 26, 140, 0.3), 0 4px 15px rgba(0,0,0,0.9);
            pointer-events: none;
            transition: color 0.3s ease;
        }

        /* --- XÚC SẮC 3D GIỮ NGUYÊN HOẠT ẢNH QUAY --- */
        .dice-area {
            position: absolute;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 18px;
            z-index: 5;
            perspective: 1000px; 
        }
        .dice-row { display: flex; gap: 25px; }

        .dice {
            width: var(--dice-size);
            height: var(--dice-size);
            position: relative;
            transform-style: preserve-3d; 
            transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.3, 1); 
        }

        .dice-face {
            position: absolute;
            width: var(--dice-size);
            height: var(--dice-size);
            background: radial-gradient(circle at 35% 35%, #ff3b3b 0%, #b30000 65%, #660000 100%);
            border: 1px solid rgba(255, 255, 255, 0.25);
            box-sizing: border-box;
            border-radius: 10px;
            box-shadow: 
                inset 0 0 6px rgba(255, 255, 255, 0.4),
                inset -3px -3px 8px rgba(0, 0, 0, 0.6),
                0 6px 12px rgba(0,0,0,0.7);
            display: grid;
            padding: 7px;
        }

        .front  { transform: rotateY(0deg) translateZ(27px); }
        .back   { transform: rotateY(180deg) translateZ(27px); }
        .right  { transform: rotateY(90deg) translateZ(27px); }
        .left   { transform: rotateY(-90deg) translateZ(27px); }
        .top    { transform: rotateX(90deg) translateZ(27px); }
        .bottom { transform: rotateX(-90deg) translateZ(27px); }

        .dot {
            width: 9px;
            height: 9px;
            background: #ffffff;
            border-radius: 50%;
            align-self: center;
            justify-self: center;
            box-shadow: 
                inset 1px 1px 3px rgba(0, 0, 0, 0.8),
                1px 1px 1.5px rgba(255, 255, 255, 0.6), 
                0px 0px 3px rgba(0, 0, 0, 0.9) inset;
        }

        .face-1 {
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .face-1 .dot { 
            width: 17px; 
            height: 17px; 
            background: radial-gradient(circle at 35% 35%, #fffb00 0%, #ff1a1a 60%, #990000 100%);
            box-shadow: 
                inset 2px 2px 5px rgba(0, 0, 0, 0.9),
                1px 1px 2px rgba(255, 255, 255, 0.5),
                0 0 5px rgba(0,0,0,0.95) inset; 
        }

        .face-2 { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; }
        .face-2 .dot:nth-child(1) { grid-area: 1 / 1; }
        .face-2 .dot:nth-child(2) { grid-area: 2 / 2; }

        .face-3 { grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr 1fr; }
        .face-3 .dot:nth-child(1) { grid-area: 1 / 1; }
        .face-3 .dot:nth-child(2) { grid-area: 2 / 2; }
        .face-3 .dot:nth-child(3) { grid-area: 3 / 3; }

        .face-4 { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; }
        .face-4 .dot:nth-child(1) { grid-area: 1 / 1; }
        .face-4 .dot:nth-child(2) { grid-area: 1 / 2; }
        .face-4 .dot:nth-child(3) { grid-area: 2 / 1; }
        .face-4 .dot:nth-child(4) { grid-area: 2 / 2; }

        .face-5 { grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr 1fr; }
        .face-5 .dot:nth-child(1) { grid-area: 1 / 1; }
        .face-5 .dot:nth-child(2) { grid-area: 1 / 3; }
        .face-5 .dot:nth-child(3) { grid-area: 2 / 2; }
        .face-5 .dot:nth-child(4) { grid-area: 3 / 1; }
        .face-5 .dot:nth-child(5) { grid-area: 3 / 3; }

        .face-6 { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr 1fr; }
        .face-6 .dot:nth-child(1) { grid-area: 1 / 1; }
        .face-6 .dot:nth-child(2) { grid-area: 1 / 2; }
        .face-6 .dot:nth-child(3) { grid-area: 2 / 1; }
        .face-6 .dot:nth-child(4) { grid-area: 2 / 2; }
        .face-6 .dot:nth-child(5) { grid-area: 3 / 1; }
        .face-6 .dot:nth-child(6) { grid-area: 3 / 2; }

        .rolling { animation: rollContinuous 3.5s linear infinite; }

        @keyframes rollContinuous {
            0% { transform: scale(1) rotateX(0deg) rotateY(0deg) rotateZ(0deg); }
            10% { transform: scale(1.3) rotateX(360deg) rotateY(180deg) rotateZ(90deg); }
            90% { transform: scale(1.3) rotateX(2520deg) rotateY(1980deg) rotateZ(630deg); }
            100% { transform: scale(1) rotateX(2880deg) rotateY(2160deg) rotateZ(720deg); }
        }

        /* --- THAY ĐỔI VỊ TRÍ & KÍCH THƯỚC: DỊCH RA NGOÀI, DÀI GẤP RƯỠI ĐỂ TRÁNH GIẬT/NHẤP NHÁY --- */
        .stage-side-box {
            position: absolute;
            width: 210px; /* Tăng chiều rộng từ 140px lên 210px (Dài thêm một nửa) */
            height: 155px;
            background: rgba(10, 2, 25, 0.75);
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(0,0,0,0.8), inset 0 0 15px rgba(255,255,255,0.05);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            z-index: 10;
            box-sizing: border-box;
            border: 2.5px solid transparent;
        }

        .stage-side-box:active {
            transform: scale(0.95) translateY(2px) !important;
        }

        /* Tài bên trái - Dịch ra xa thêm một nửa (từ 5px -> 55px) */
        .side-tai {
            left: -55px; 
            border-color: rgba(179, 18, 23, 0.6);
        }
        /* Xỉu bên phải - Dịch ra xa thêm một nửa (từ 5px -> 55px) */
        .side-xiu {
            right: -55px; 
            border-color: rgba(28, 117, 188, 0.6);
        }

        /* Trạng thái được chọn */
        .stage-side-box.selected-target {
            background: rgba(20, 4, 40, 0.9);
            transform: scale(1.05);
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.15), inset 0 0 20px rgba(255, 255, 255, 0.08);
        }
        .side-tai.selected-target {
            border-color: #ff3333;
            box-shadow: 0 0 25px rgba(255, 51, 51, 0.35);
        }
        .side-xiu.selected-target {
            border-color: #3399ff;
            box-shadow: 0 0 25px rgba(51, 153, 255, 0.35);
        }

        /* Hiệu ứng nhấp nháy thắng cuộc */
        @keyframes flashWinning {
            0%, 100% { background: rgba(255, 255, 255, 0.1); }
            50% { background: rgba(255, 215, 0, 0.45); border-color: #ffd700; box-shadow: 0 0 30px #ffd700, inset 0 0 20px #ffd700; }
        }
        .stage-side-box.winning-flash {
            animation: flashWinning 0.4s ease-in-out infinite;
        }

        .side-title {
            font-size: 38px;
            font-weight: 950;
            margin: 0;
            letter-spacing: 2px;
            text-shadow: 0 3px 6px rgba(0,0,0,0.9);
        }
        .side-tai .side-title { color: #ff4d4d; }
        .side-xiu .side-title { color: #4dadff; }

        .side-desc {
            font-size: 10px;
            color: #aaaaaa;
            margin-top: 1px;
            font-weight: bold;
        }

        .side-player-bet {
            margin-top: 8px;
            width: 160px; /* Tăng độ rộng để hiển thị thoải mái số tiền lớn */
            height: 28px;
            background: linear-gradient(135deg, #111 0%, #222 100%);
            border: 1.5px solid #444;
            border-radius: 14px;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.5);
        }

        /* CHỮ SỐ CỰC KỲ LINH HOẠT SINH ĐỘNG NHẤP NHÁY */
        @keyframes pulseBetValueTai {
            0%, 100% { transform: scale(1); filter: drop-shadow(0 0 2px rgba(255, 77, 77, 0.3)); color: #ff9999; }
            50% { transform: scale(1.08); filter: drop-shadow(0 0 8px rgba(255, 77, 77, 0.8)); color: #ff3333; }
        }
        @keyframes pulseBetValueXiu {
            0%, 100% { transform: scale(1); filter: drop-shadow(0 0 2px rgba(77, 173, 255, 0.3)); color: #99ccff; }
            50% { transform: scale(1.08); filter: drop-shadow(0 0 8px rgba(77, 173, 255, 0.8)); color: #3399ff; }
        }

        .side-tai .pulse-text {
            animation: pulseBetValueTai 2s infinite ease-in-out;
        }
        .side-xiu .pulse-text {
            animation: pulseBetValueXiu 2s infinite ease-in-out;
        }

        .side-player-bet-value {
            font-size: 11px;
            font-weight: 800;
        }

        .side-total-bet {
            font-size: 14px;
            font-weight: 900;
            margin-top: 6px;
            letter-spacing: 0.5px;
            text-align: center;
            width: 90%;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* --- HIỆU ỨNG THẮNG CỘNG TIỀN BAY LÊN THỰC TẾ --- */
        .win-animate-text {
            position: absolute;
            font-size: 24px;
            font-weight: 900;
            background: linear-gradient(to bottom, #ffea00 0%, #ff6600 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 10px rgba(255, 102, 0, 0.8), 0 2px 5px rgba(0,0,0,1);
            pointer-events: none;
            z-index: 99;
            animation: floatUpWin 7s forwards linear;
            text-align: center;
            width: 100%;
        }

        @keyframes floatUpWin {
            0% { opacity: 0; transform: translateY(40px) scale(0.7); }
            5% { opacity: 1; transform: translateY(10px) scale(1.1); }
            20% { transform: translateY(-20px) scale(1); }
            80% { opacity: 1; transform: translateY(-100px) scale(1); }
            100% { opacity: 0; transform: translateY(-140px) scale(0.8); }
        }

        /* --- KHU VỰC CƯỢC TỰ DO TỰ NHẬP TIỀN BẤT KỲ --- */
        .custom-bet-container {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 15px;
            background: rgba(0, 0, 0, 0.8);
            padding: 8px 15px;
            border-radius: 12px;
            border: 1px solid #d4af37;
            z-index: 10;
        }
        .custom-bet-label {
            color: #ffd700;
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
        }
        .custom-bet-input {
            width: 140px;
            background: #111;
            border: 1px solid #555;
            color: #00ff88;
            padding: 6px 10px;
            border-radius: 6px;
            font-weight: bold;
            font-size: 14px;
            outline: none;
            text-align: center;
        }
        .btn-quick-bet {
            padding: 6px 12px;
            background: #222;
            border: 1px solid #ffd700;
            color: #ffd700;
            font-size: 11px;
            font-weight: bold;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .btn-quick-bet:hover {
            background: #ffd700;
            color: #000;
        }

        /* --- KHU VỰC CHIP CỰC ĐẸP --- */
        .chip-container {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
            background: rgba(0, 0, 0, 0.7);
            padding: 10px 15px;
            border-radius: 35px;
            border: 1.5px solid rgba(255, 215, 0, 0.2);
            z-index: 2;
            flex-wrap: wrap;
            max-width: 550px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        }

        .chip {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 10px;
            font-weight: bold;
            color: white;
            cursor: pointer;
            position: relative;
            border: 3px dashed rgba(255, 255, 255, 0.6);
            box-shadow: 0 4px 6px rgba(0,0,0,0.4), inset 0 0 8px rgba(0,0,0,0.5);
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .chip[data-value="1K"]   { background: #777777; transform: scale(0.85); }
        .chip[data-value="10K"]  { background: #aa66cc; transform: scale(0.9); }
        .chip[data-value="50K"]  { background: #1b75bc; transform: scale(0.95); }
        .chip[data-value="100K"] { background: #39b54a; transform: scale(1.0); }
        .chip[data-value="500K"] { background: #f7931e; transform: scale(1.05); }
        .chip[data-value="1M"]   { background: #b31217; transform: scale(1.1); }
        .chip[data-value="200M"] { background: linear-gradient(135deg, #e00096, #4a0080); transform: scale(1.15); border-color: #ffb3e6; }
        .chip[data-value="500M"] { background: linear-gradient(135deg, #00e5ff, #0033cc); transform: scale(1.2); border-color: #e0ffff; }

        .chip::after {
            content: attr(data-value);
            position: absolute;
            width: 26px;
            height: 26px;
            background: rgba(255,255,255,0.15);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 8px;
        }

        .chip.selected {
            transform: translateY(-8px) scale(1.2) !important;
            box-shadow: 0 8px 15px rgba(0,0,0,0.5), 0 0 10px #00ff88;
            z-index: 3;
        }

        /* --- NÚT BẤM 3D CHÂN THỰC --- */
        .control-btns { display: flex; gap: 15px; margin-top: 15px; z-index: 2; }
        .btn-action {
            padding: 10px 22px; 
            font-size: 13px; 
            font-weight: bold; 
            color: white; 
            border-radius: 10px; 
            cursor: pointer; 
            text-transform: uppercase; 
            letter-spacing: 1px; 
            transition: all 0.15s ease;
            box-sizing: border-box;
            border-bottom: 4px solid rgba(0,0,0,0.5);
            text-shadow: 0 1.5px 3px rgba(0,0,0,0.8);
        }
        .btn-cancel { 
            background: linear-gradient(to bottom, #777, #444); 
            border: 1px solid #555; 
            border-bottom-width: 4px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }
        .btn-cancel:active {
            transform: translateY(2px);
            border-bottom-width: 2px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.5);
        }
        .btn-allin { 
            background: linear-gradient(to bottom, #ffaa00, #cc6600); 
            border: 1px solid #ffcc00; 
            border-bottom-width: 4px;
            box-shadow: 0 4px 12px rgba(255, 102, 0, 0.4);
        }
        .btn-allin:active {
            transform: translateY(2px);
            border-bottom-width: 2px;
            box-shadow: 0 2px 6px rgba(255, 102, 0, 0.4);
        }

        .overlay-screen {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 100; opacity: 0; pointer-events: none; transition: opacity 0.4s ease;
        }
        .overlay-screen.active { opacity: 1; pointer-events: auto; }
        .screen-lose { background: rgba(20, 10, 10, 0.85); }
        .lose-box { background: #1a1111; border: 3px solid #553333; padding: 30px 50px; border-radius: 20px; text-align: center; box-shadow: 0 0 20px rgba(0,0,0,0.8); }
        .lose-title { font-size: 36px; font-weight: 800; color: #cc3333; margin: 0 0 10px 0; letter-spacing: 2px; }
        .lose-msg { color: #999999; font-size: 16px; margin: 0; }
    </style>
</head>
<body>

    <!-- ĐỊNH NGHĨA GRADIENT SÁNG MƯỢT CHO VÒNG TRÒN THỜI GIAN -->
    <svg width="0" height="0" style="position: absolute;">
        <defs>
            <linearGradient id="neonGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#ffea00" />    
                <stop offset="35%" stop-color="#ff9900" />   
                <stop offset="70%" stop-color="#ff007f" />   
                <stop offset="100%" stop-color="#ff0000" />  
            </linearGradient>
        </defs>
    </svg>

    <div class="top-navigation">
        <div class="header-bar">
            <span class="balance-label">Số Dư Khả Dụng:</span>
            <span id="accountBalance" class="balance-amount">2.000.000đ</span>
        </div>
        <button class="btn-deposit" onclick="virtualDeposit()">+ Nạp 2.000.000đ</button>
        <button class="btn-withdraw" onclick="openWithdrawModal()">Rút tiền</button>
    </div>

    <!-- LOGO HIỆU ỨNG HOÀNG GIA CHUYỂN ĐỘNG ÁNH KIM -->
    <div class="casino-logo-container" id="logoContainer">
        <div class="casino-logo">
            Sic Bo Premium
            <span>LIVE MACAU CLUB</span>
        </div>
    </div>

    <div class="main-stage">
        <div id="status" class="status-text">Đang chờ...</div>

        <!-- Ô CƯỢC TÀI XẾP LÊN GIỮA CẠNH TRÁI VÒNG TRÒN (DỊCH RỘNG, DÀI HƠN) -->
        <div id="boxTai" class="stage-side-box side-tai" onclick="handleSelectTarget('TÀI')">
            <span class="side-title">TÀI</span>
            <span class="side-desc">11 - 17 (1 ăn 1)</span>
            <div class="side-player-bet">
                <span id="myBetTaiValue" class="side-player-bet-value pulse-text">0đ</span>
            </div>
            <span id="totalBetTai" class="side-total-bet pulse-text">Tổng: 0đ</span>
        </div>

        <!-- VÒNG TRÒN ĐẾM THỜI GIAN ĐÃ GIẢM CHÓI -->
        <svg id="progressSvg" class="progress-ring" width="260" height="260">
            <circle class="progress-ring__circle" cx="130" cy="130" r="120"></circle>
            <circle id="bar" class="progress-ring__bar" cx="130" cy="130" r="120"></circle>
        </svg>

        <div id="countdown" class="countdown-number">26</div>

        <!-- KHU VỰC CHỨA XÚC SẮC TRUNG TÂM -->
        <div class="dice-area" id="diceArea">
            <div class="dice-row">
                <!-- Xúc sắc 1 -->
                <div class="dice" id="d1">
                    <div class="dice-face front face-1"><div class="dot"></div></div>
                    <div class="dice-face back face-6"><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
                    <div class="dice-face right face-2"><div class="dot"></div><div class="dot"></div></div>
                    <div class="dice-face left face-5"><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
                    <div class="dice-face top face-3"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
                    <div class="dice-face bottom face-4"><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
                </div>
                <!-- Xúc sắc 2 -->
                <div class="dice" id="d2">
                    <div class="dice-face front face-1"><div class="dot"></div></div>
                    <div class="dice-face back face-6"><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
                    <div class="dice-face right face-2"><div class="dot"></div><div class="dot"></div></div>
                    <div class="dice-face left face-5"><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
                    <div class="dice-face top face-3"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
                    <div class="dice-face bottom face-4"><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
                </div>
            </div>
            <!-- Xúc sắc 3 -->
            <div class="dice" id="d3">
                <div class="dice-face front face-1"><div class="dot"></div></div>
                <div class="dice-face back face-6"><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
                <div class="dice-face right face-2"><div class="dot"></div><div class="dot"></div></div>
                <div class="dice-face left face-5"><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
                <div class="dice-face top face-3"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
                <div class="dice-face bottom face-4"><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
            </div>
        </div>

        <!-- Ô CƯỢC XỈU XẾP LÊN GIỮA CẠNH PHẢI VÒNG TRÒN (DỊCH RỘNG, DÀI HƠN) -->
        <div id="boxXiu" class="stage-side-box side-xiu" onclick="handleSelectTarget('XỈU')">
            <span class="side-title">XỈU</span>
            <span class="side-desc">4 - 10 (1 ăn 1)</span>
            <div class="side-player-bet">
                <span id="myBetXiuValue" class="side-player-bet-value pulse-text">0đ</span>
            </div>
            <span id="totalBetXiu" class="side-total-bet pulse-text">Tổng: 0đ</span>
        </div>
    </div>

    <!-- KHU VỰC CƯỢC BAO NHIÊU CŨNG ĐƯỢC -->
    <div class="custom-bet-container">
        <span class="custom-bet-label">Nhập Cược Tự Do:</span>
        <input type="number" id="customBetInput" class="custom-bet-input" value="1000" min="100" placeholder="Số tiền..." oninput="updateCustomBetValue(this.value)">
        <button class="btn-quick-bet" onclick="quickBetMultiply(0.5)">/ 2</button>
        <button class="btn-quick-bet" onclick="quickBetMultiply(2)">x 2</button>
    </div>

    <!-- BẢNG NÚT BẤM ĐIỀU KHIỂN -->
    <div class="control-btns">
        <button class="btn-action btn-cancel" onclick="cancelAllBets()">Hủy Cược</button>
        <button class="btn-action btn-allin" onclick="triggerAllIn()">All-In Tất Tay</button>
    </div>

    <!-- KHU VỰC KHAY CHIP -->
    <div class="chip-container">
        <div class="chip selected" id="chip-1K" data-value="1K" onclick="selectChip(this, 1000)"></div>
        <div class="chip" id="chip-10K" data-value="10K" onclick="selectChip(this, 10000)"></div>
        <div class="chip" id="chip-50K" data-value="50K" onclick="selectChip(this, 50000)"></div>
        <div class="chip" id="chip-100K" data-value="100K" onclick="selectChip(this, 100000)"></div>
        <div class="chip" id="chip-500K" data-value="500K" onclick="selectChip(this, 500000)"></div>
        <div class="chip" id="chip-1M" data-value="1M" onclick="selectChip(this, 1000000)"></div>
        <div class="chip" id="chip-200M" data-value="200M" onclick="selectChip(this, 200000000)"></div>
        <div class="chip" id="chip-500M" data-value="500M" onclick="selectChip(this, 500000000)"></div>
    </div>

    <!-- MÀN HÌNH THUA CUỘC -->
    <div id="loseScreen" class="overlay-screen screen-lose">
        <div class="lose-box">
            <div class="lose-title">YOU LOSE</div>
            <div class="lose-msg">Rất tiếc, may mắn sẽ đến vào lần sau!</div>
        </div>
    </div>

    <script>
        const bar = document.getElementById('bar');
        const countdownEl = document.getElementById('countdown');
        const statusEl = document.getElementById('status');
        const progressSvg = document.getElementById('progressSvg');
        const diceElements = [document.getElementById('d1'), document.getElementById('d2'), document.getElementById('d3')];
        const balanceEl = document.getElementById('accountBalance');
        const statusXiuEl = document.getElementById('totalBetXiu');
        const statusTaiEl = document.getElementById('totalBetTai');
        const boxXiu = document.getElementById('boxXiu');
        const boxTai = document.getElementById('boxTai');

        const myBetXiuValueEl = document.getElementById('myBetXiuValue');
        const myBetTaiValueEl = document.getElementById('myBetTaiValue');
        const customBetInput = document.getElementById('customBetInput');

        let timeWait = 26;
        const circumference = 2 * Math.PI * 120;
        bar.style.strokeDasharray = circumference;

        const faceTransforms = {
            1: { x: 0,   y: 0 }, 
            2: { x: 0,   y: -90 }, 
            3: { x: -90, y: 0 },
            4: { x: 90,  y: 0 }, 
            5: { x: 0,   y: 90 },  
            6: { x: 180, y: 0 }
        };

        let userBalance = 2000000;
        let currentSelectedValue = 1000; 
        let currentSelectedTarget = 'XỈU'; 
        
        let totalXiuBet = 0;
        let totalTaiBet = 0;
        let displayXiuBet = 0; 
        let displayTaiBet = 0; 
        let myXiuBet = 0;
        let myTaiBet = 0;

        let isBettingAllowed = true;
        let finalResults = [1, 1, 1];
        let loopTimer = null;
        let botBetInterval = null;

        // Thiết lập trạng thái ô cược mặc định khi mở game
        document.getElementById('boxXiu').classList.add('selected-target');
        startNewGameSession();

        function animateBetNumbers() {
            if (displayXiuBet < totalXiuBet) {
                let diffXiu = totalXiuBet - displayXiuBet;
                let stepXiu = Math.ceil(diffXiu * 0.25); 
                if (diffXiu > 10000000) stepXiu = Math.ceil(diffXiu * 0.4); 
                displayXiuBet += stepXiu;
            } else if (displayXiuBet > totalXiuBet) {
                displayXiuBet = totalXiuBet;
            }

            if (displayTaiBet < totalTaiBet) {
                let diffTai = totalTaiBet - displayTaiBet;
                let stepTai = Math.ceil(diffTai * 0.25);
                if (diffTai > 10000000) stepTai = Math.ceil(diffTai * 0.4);
                displayTaiBet += stepTai;
            } else if (displayTaiBet > totalTaiBet) {
                displayTaiBet = totalTaiBet;
            }

            statusXiuEl.innerText = `Tổng: ${formatMoney(displayXiuBet)}`;
            statusTaiEl.innerText = `Tổng: ${formatMoney(displayTaiBet)}`;
            requestAnimationFrame(animateBetNumbers);
        }
        requestAnimationFrame(animateBetNumbers);

        // Nâng cấp: Cho phép người dùng nhập tự do bất kỳ số tiền cược nào
        function updateCustomBetValue(val) {
            let numericVal = parseInt(val);
            if (isNaN(numericVal) || numericVal <= 0) {
                currentSelectedValue = 0;
                return;
            }
            currentSelectedValue = numericVal;
            
            // Bỏ chọn hiệu ứng bay của các chip tròn tĩnh khi nhập tay
            document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
        }

        // Tăng hoặc giảm nhanh tiền cược (/2 hoặc x2)
        function quickBetMultiply(factor) {
            let current = parseInt(customBetInput.value) || 1000;
            let newVal = Math.max(100, Math.floor(current * factor));
            customBetInput.value = newVal;
            updateCustomBetValue(newVal);
        }

        // Hàm click chọn chip cũ vẫn hoạt động và đồng bộ hóa với thanh nhập tay
        function selectChip(element, value) {
            document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
            element.classList.add('selected');
            currentSelectedValue = value;
            customBetInput.value = value;
        }

        function formatMoney(amount) {
            if (amount >= 1000000000) {
                return (amount / 1000000000).toFixed(1).replace('.0', '') + ' tỷ';
            }
            if (amount >= 1000000) {
                return (amount / 1000000).toFixed(1).replace('.0', '') + 'M';
            }
            if (amount >= 1000) {
                return (amount / 1000).toFixed(0) + 'K';
            }
            return amount + 'đ';
        }

        function handleSelectTarget(target) {
            if (!isBettingAllowed) return;
            
            currentSelectedTarget = target;
            boxXiu.classList.remove('selected-target');
            boxTai.classList.remove('selected-target');

            if (target === 'XỈU') {
                boxXiu.classList.add('selected-target');
            } else {
                boxTai.classList.add('selected-target');
            }

            // Thao tác cược luôn khi click chọn ô
            if (currentSelectedValue > 0) {
                placeBet(currentSelectedValue);
            }
        }

        function placeBet(amount) {
            if (!isBettingAllowed) return;
            if (userBalance < amount) {
                alert("Số dư không đủ để cược!");
                return;
            }

            userBalance -= amount;
            updateBalanceUI();

            if (currentSelectedTarget === 'XỈU') {
                myXiuBet += amount;
                totalXiuBet += amount;
                myBetXiuValueEl.innerText = formatMoney(myXiuBet);
            } else {
                myTaiBet += amount;
                totalTaiBet += amount;
                myBetTaiValueEl.innerText = formatMoney(myTaiBet);
            }
        }

        function updateBalanceUI() {
            balanceEl.innerText = userBalance.toLocaleString('vi-VN') + 'đ';
        }

        function cancelAllBets() {
            if (!isBettingAllowed) return;
            userBalance += (myXiuBet + myTaiBet);
            totalXiuBet -= myXiuBet;
            totalTaiBet -= myTaiBet;
            myXiuBet = 0;
            myTaiBet = 0;
            myBetXiuValueEl.innerText = "0đ";
            myBetTaiValueEl.innerText = "0đ";
            updateBalanceUI();
        }

        function triggerAllIn() {
            if (!isBettingAllowed || userBalance <= 0) return;
            let tempAllIn = userBalance;
            placeBet(tempAllIn);
        }

        function virtualDeposit() {
            userBalance += 2000000;
            updateBalanceUI();
            document.getElementById('loseScreen').classList.remove('active');
        }

        function openWithdrawModal() {
            alert(`Bạn đang thực hiện yêu cầu rút toàn bộ số dư: ${userBalance.toLocaleString('vi-VN')}đ về tài khoản ngân hàng!`);
        }

        function startNewGameSession() {
            isBettingAllowed = true;
            timeWait = 26;
            countdownEl.classList.remove('pulse-active');
            countdownEl.style.color = "rgba(255, 255, 255, 0.45)";
            statusEl.innerText = "Đầu phiên - Xin mời đặt cược";
            statusEl.style.color = "#00ff88";

            // Xóa hiệu ứng thắng cũ
            boxXiu.classList.remove('winning-flash');
            boxTai.classList.remove('winning-flash');

            // Xóa cược cũ của người dùng
            myXiuBet = 0;
            myTaiBet = 0;
            myBetXiuValueEl.innerText = "0đ";
            myBetTaiValueEl.innerText = "0đ";

            // Reset tổng cược cũ
            totalXiuBet = Math.floor(Math.random() * 2000000) + 1000000;
            totalTaiBet = Math.floor(Math.random() * 2000000) + 1000000;

            // Dừng xúc sắc quay
            diceElements.forEach(d => d.classList.remove('rolling'));

            startTimer();
            startBotBets();
        }

        function startTimer() {
            if (loopTimer) clearInterval(loopTimer);
            loopTimer = setInterval(() => {
                timeWait--;
                countdownEl.innerText = timeWait;

                let progress = (timeWait / 26) * circumference;
                bar.style.strokeDashoffset = circumference - progress;

                if (timeWait <= 5 && timeWait > 0) {
                    countdownEl.classList.add('pulse-active');
                    countdownEl.style.color = "#ff3333";
                    statusEl.innerText = "Sắp khóa cược!";
                    statusEl.style.color = "#ff3333";
                }

                if (timeWait <= 0) {
                    clearInterval(loopTimer);
                    stopBotBets();
                    handleLockAndRoll();
                }
            }, 1000);
        }

        function startBotBets() {
            if (botBetInterval) clearInterval(botBetInterval);
            botBetInterval = setInterval(() => {
                if (timeWait > 1) {
                    totalXiuBet += Math.floor(Math.random() * 150000) + 20000;
                    totalTaiBet += Math.floor(Math.random() * 150000) + 20000;
                }
            }, 250);
        }

        function stopBotBets() {
            if (botBetInterval) clearInterval(botBetInterval);
        }

        function handleLockAndRoll() {
            isBettingAllowed = false;
            statusEl.innerText = "Ngừng nhận cược - Đang xúc...";
            statusEl.style.color = "#ffd700";

            // Tạo kết quả ngẫu nhiên
            finalResults = [
                Math.floor(Math.random() * 6) + 1,
                Math.floor(Math.random() * 6) + 1,
                Math.floor(Math.random() * 6) + 1
            ];

            // Chạy hoạt ảnh quay xúc sắc
            diceElements.forEach(d => d.classList.add('rolling'));

            setTimeout(() => {
                diceElements.forEach(d => d.classList.remove('rolling'));
                setDiceResult(finalResults);
                processGameResult();
            }, 3500);
        }

        function setDiceResult(results) {
            for (let i = 0; i < 3; i++) {
                let val = results[i];
                let trans = faceTransforms[val];
                diceElements[i].style.transform = `rotateX(${trans.x}deg) rotateY(${trans.y}deg)`;
            }
        }

        function processGameResult() {
            let sum = finalResults.reduce((a, b) => a + b, 0);
            let resultText = (sum >= 11) ? 'TÀI' : 'XỈU';
            
            statusEl.innerText = `Kết quả: ${sum} nút - ${resultText}`;
            statusEl.style.color = (resultText === 'TÀI') ? '#ff4d4d' : '#4dadff';

            // Nhấp nháy hộp thắng cuộc
            if (resultText === 'TÀI') {
                boxTai.classList.add('winning-flash');
                if (myTaiBet > 0) {
                    let winAmount = myTaiBet * 2;
                    userBalance += winAmount;
                    spawnWinText(boxTai, `+${winAmount.toLocaleString('vi-VN')}đ`);
                }
            } else {
                boxXiu.classList.add('winning-flash');
                if (myXiuBet > 0) {
                    let winAmount = myXiuBet * 2;
                    userBalance += winAmount;
                    spawnWinText(boxXiu, `+${winAmount.toLocaleString('vi-VN')}đ`);
                }
            }

            updateBalanceUI();

            // Nếu người chơi hết sạch tiền, hiện màn hình thua sau vài giây
            if (userBalance <= 0 && myXiuBet === 0 && myTaiBet === 0) {
                setTimeout(() => {
                    document.getElementById('loseScreen').classList.add('active');
                }, 1500);
            }

            // Chờ 5 giây rồi chạy phiên mới
            setTimeout(() => {
                startNewGameSession();
            }, 5000);
        }

        function spawnWinText(parent, text) {
            let animateText = document.createElement('div');
            animateText.className = 'win-animate-text';
            animateText.innerText = text;
            parent.appendChild(animateText);
            setTimeout(() => {
                animateText.remove();
            }, 6000);
        }
    </script>
</body>
</html>
