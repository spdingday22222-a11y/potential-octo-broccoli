// javascript.js - Hàm xử lý khi user bấm nút "Đổi Thưởng"
async function requestRealReward(itemId) {
    const userToken = localStorage.getItem('user_jwt_token'); // Token xác thực đăng nhập

    try {
        const response = await fetch('https://api.domain-cua-ban.com/api/rewards/redeem', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${userToken}` // Gửi kèm token để Server nhận diện
            },
            body: JSON.stringify({ item_id: itemId })
        });

        const result = await response.json();

        if (response.ok) {
            alert("Đổi thưởng thành công! Quà đang được xử lý.");
            // Cập nhật lại số dư trên giao diện (ví dụ lấy từ API về)
        } else {
            alert("Lỗi: " + result.message); // Ví dụ: "Không đủ điểm" hoặc "Lỗi hệ thống"
        }
    } catch (error) {
        console.error("Lỗi kết nối:", error);
    }
}


