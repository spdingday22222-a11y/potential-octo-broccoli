// Server Node.js (Express)
app.post('/api/rewards/redeem', verifyToken, async (req, res) => {
    const userId = req.user.id; // Lấy từ Token
    const itemId = req.body.item_id;
    
    // Bắt đầu MySQL Transaction để chống lỗi bất đồng bộ
    const connection = await db.getConnection();
    await connection.beginTransaction();

    try {
        // 1. Kiểm tra vật phẩm và giá tiền
        const [items] = await connection.execute('SELECT price, stock FROM items WHERE id = ? FOR UPDATE', [itemId]);
        if (items.length === 0 || items[0].stock <= 0) throw new Error("Hết quà");
        const price = items[0].price;

        // 2. Kiểm tra số dư người dùng (khóa row này lại để không bị trừ đúp - FOR UPDATE)
        const [users] = await connection.execute('SELECT balance FROM users WHERE id = ? FOR UPDATE', [userId]);
        if (users[0].balance < price) throw new Error("Không đủ điểm");

        // 3. Trừ tiền người dùng
        await connection.execute('UPDATE users SET balance = balance - ? WHERE id = ?', [price, userId]);

        // 4. Trừ số lượng quà và ghi lịch sử
        await connection.execute('UPDATE items SET stock = stock - 1 WHERE id = ?', [itemId]);
        await connection.execute('INSERT INTO reward_history (user_id, item_id, status) VALUES (?, ?, "PENDING")', [userId, itemId]);

        // Hoàn tất giao dịch an toàn
        await connection.commit();
        res.status(200).json({ message: "Thành công" });

    } catch (error) {
        // Nếu có bất kỳ lỗi nào, hủy toàn bộ thao tác (Rollback)
        await connection.rollback();
        res.status(400).json({ message: error.message });
    } finally {
        connection.release();
    }
});

