document.getElementById('withdrawBtn').addEventListener('click', async function() {
    // 1. Lấy dữ liệu người dùng nhập
    const bankName = document.getElementById('bankName').value;
    const bankAccount = document.getElementById('bankAccount').value;
    const amount = parseInt(document.getElementById('amount').value);
    
    const btn = document.getElementById('withdrawBtn');
    const statusMsg = document.getElementById('statusMessage');

    // 2. Kiểm tra sơ bộ ở Frontend
    if (!bankAccount || isNaN(amount) || amount < 50000) {
        showStatus("Vui lòng nhập đúng STK và số tiền tối thiểu 50.000 VNĐ", "error");
        return;
    }

    // 3. Khóa nút bấm để chống spam (Rate Limiting phía Client)
    btn.disabled = true;
    btn.innerText = "Đang xử lý giao dịch...";
    statusMsg.classList.add("hidden");

    try {
        // Lấy token xác thực của người dùng (giả sử bạn lưu lúc họ đăng nhập)
        const userToken = localStorage.getItem('user_token'); 

        // 4. GỬI YÊU CẦU LÊN SERVER CỦA BẠN (Không phải gửi cho ngân hàng)
        // Thay bằng URL Server thật của bạn
        const response = await fetch('https://api.server-cua-ban.com/api/withdraw', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${userToken}` 
            },
            body: JSON.stringify({
                bank_name: bankName,
                account_number: bankAccount,
                amount: amount
            })
        });

        // Đợi Server của bạn gọi ngân hàng và trả về kết quả
        const result = await response.json();

        // 5. Hiển thị kết quả cho người dùng
        if (response.ok) {
            showStatus("Thành công! Tiền đang được chuyển về tài khoản của bạn.", "success");
            // Cập nhật lại số dư trên màn hình
            document.getElementById('userBalance').innerText = (parseInt(document.getElementById('userBalance').innerText.replace(/,/g, '')) - amount).toLocaleString();
        } else {
            // Lỗi từ Server (VD: Số dư không đủ, hoặc ngân hàng từ chối)
            showStatus("Giao dịch thất bại: " + result.message, "error");
        }

    } catch (error) {
        console.error("Lỗi:", error);
        showStatus("Lỗi kết nối đến máy chủ. Vui lòng thử lại sau.", "error");
    } finally {
        // Mở khóa lại nút bấm sau khi xử lý xong
        btn.disabled = false;
        btn.innerText = "Xác Nhận Rút Tiền";
    }
});

// Hàm hỗ trợ hiển thị thông báo
function showStatus(message, type) {
    const statusMsg = document.getElementById('statusMessage');
    statusMsg.innerText = message;
    statusMsg.className = type; // add class "success" or "error"
    statusMsg.classList.remove("hidden");
}


