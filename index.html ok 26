    <div id="loseScreen" class="overlay-screen screen-lose">
        <div class="lose-box">
            <h1 class="lose-title">HẾT VỐN</h1>
            <p class="lose-msg">Bạn đã thua sạch tiền! Hệ thống sẽ nạp lại vốn 2.000.000đ tự động sau vài giây...</p>
        </div>
    </div>

    <script>
        // --- KHỞI TẠO BIẾN TOÀN CỤC ---
        let balance = 2000000;
        let activeChipValue = 1000;
        let selectedTarget = null; // 'TÀI' hoặc 'XỈU'

        let myBetTai = 0;
        let myBetXiu = 0;
        let simulatedTotalTai = 0;
        let simulatedTotalXiu = 0;

        let gameState = 'WAITING'; // WAITING, ROLLING, SQUEEZING, SHOWING
        let timeRemaining = 26;
        let countdownTimer = null;
        let simulatedBetsTimer = null;

        // Lưu góc xoay ứng với số mặt xúc sắc hiển thị lên phía trên cùng
        const faceRotations = {
            1: { x: 0,   y: 0   },   // front (mặt 1)
            6: { x: 180, y: 0   },   // back (mặt 6)
            2: { x: 0,   y: -90 },   // right (mặt 2)
            5: { x: 0,   y: 90  },   // left (mặt 5)
            3: { x: -90, y: 0   },   // top (mặt 3)
            4: { x: 90,  y: 0   }    // bottom (mặt 4)
        };

        window.onload = function() {
            updateBalanceUI();
            startNewGameLoop();
        };

        // --- HỆ THỐNG VÒNG LẶP ĐIỀU HÀNH GAME ---
        function startNewGameLoop() {
            clearInterval(countdownTimer);
            clearInterval(simulatedBetsTimer);
            
            gameState = 'WAITING';
            timeRemaining = 26;
            
            // Đặt lại các giao diện đặt cược
            document.getElementById('status').textContent = "BẮT ĐẦU ĐẶT CƯỢC";
            document.getElementById('status').style.color = "#ffffff";
            
            // Reset các giá trị cược cục bộ
            myBetTai = 0;
            myBetXiu = 0;
            simulatedTotalTai = 0;
            simulatedTotalXiu = 0;
            selectedTarget = null;
            
            // Xóa hiệu ứng CSS cũ
            document.querySelectorAll('.stage-side-box').forEach(el => {
                el.classList.remove('selected-target', 'winning-flash');
            });
            
            updateBetsUI();
            
            // Ẩn nắp, ẩn xúc sắc khi chuẩn bị vòng mới
            const lid = document.getElementById('stageLid');
            lid.style.display = 'none';
            lid.style.opacity = '0';
            lid.style.transform = 'translate(0,0)';
            
            document.getElementById('diceArea').style.opacity = '0';
            document.getElementById('countdown').style.display = 'block';
            document.getElementById('countdown').classList.remove('pulse-active');
            document.getElementById('progressSvg').style.transform = 'rotate(-90deg) scale(1)';

            // Bắt đầu đếm ngược
            runCountdown();
            startSimulatingRobotBets();
        }

        function runCountdown() {
            updateProgressCircle(timeRemaining, 26);
            document.getElementById('countdown').textContent = timeRemaining;

            countdownTimer = setInterval(() => {
                timeRemaining--;
                if (timeRemaining < 0) {
                    clearInterval(countdownTimer);
                    clearInterval(simulatedBetsTimer);
                    triggerRollingPhase();
                    return;
                }
                
                document.getElementById('countdown').textContent = timeRemaining;
                updateProgressCircle(timeRemaining, 26);

                if (timeRemaining <= 5) {
                    document.getElementById('countdown').style.color = '#ff1a8c';
                    document.getElementById('countdown').classList.add('pulse-active');
                } else {
                    document.getElementById('countdown').style.color = 'rgba(255, 255, 255, 0.45)';
                }
            }, 1000);
        }

        // --- GIAI ĐOẠN 1: ĐẢO LẮC XÚC SẮC (ROLLING) ---
        function triggerRollingPhase() {
            gameState = 'ROLLING';
            document.getElementById('status').textContent = "ĐANG KHÓA CƯỢC & LẮC...";
            document.getElementById('status').style.color = "#ffd700";
            document.getElementById('countdown').style.display = 'none';

            // Đảm bảo ẩn hoàn toàn bát nắp khi đang lắc đảo
            const lid = document.getElementById('stageLid');
            lid.style.display = 'none';
            lid.style.opacity = '0';

            // Bật hoạt ảnh xoay 3D liên tục cho xúc sắc
            const d1 = document.getElementById('d1');
            const d2 = document.getElementById('d2');
            const d3 = document.getElementById('d3');

            d1.classList.add('rolling');
            d2.classList.add('rolling');
            d3.classList.add('rolling');

            document.getElementById('diceArea').style.opacity = '1';

            // Thời gian lắc đảo xúc sắc trong 3.5 giây
            setTimeout(() => {
                // Dừng hoạt ảnh lăn đảo liên tục để chuẩn bị chuyển sang nặn nắp
                d1.classList.remove('rolling');
                d2.classList.remove('rolling');
                d3.classList.remove('rolling');

                triggerSqueezePhase();
            }, 3500);
        }

        // --- GIAI ĐOẠN 2: NẶN BÁT (SQUEEZING) ---
        function triggerSqueezePhase() {
            gameState = 'SQUEEZING';
            document.getElementById('status').textContent = "HÃY RÊ CHUỘT / KÉO NẮP ĐỂ MỞ THƯỞNG!";
            document.getElementById('status').style.color = "#ffea00";

            // Tạo kết quả ngẫu nhiên trước khi dừng hẳn xúc sắc
            const r1 = Math.floor(Math.random() * 6) + 1;
            const r2 = Math.floor(Math.random() * 6) + 1;
            const r3 = Math.floor(Math.random() * 6) + 1;
            const sum = r1 + r2 + r3;
            const gameResult = (sum >= 11) ? 'TÀI' : 'XỈU';

            // Định vị các mặt dừng chính xác cho 3 viên xúc sắc dựa trên kết quả đã tính toán
            applyDiceFaces(r1, r2, r3);

            // Bắt đầu giai đoạn nặn: Xuất hiện nắp đậy che xúc sắc lại
            const lid = document.getElementById('stageLid');
            lid.style.display = 'block';
            setTimeout(() => { lid.style.opacity = '1'; }, 50);

            // Gán logic tương tác vuốt kéo nắp đậy chân thực
            initLidDragLogic(gameResult, sum, r1, r2, r3);
        }

        function applyDiceFaces(v1, v2, v3) {
            const d1 = document.getElementById('d1');
            const d2 = document.getElementById('d2');
            const d3 = document.getElementById('d3');

            // Xoay tự do góc 3D ngẫu nhiên để tạo cảm giác sống động, nhưng kết quả vẫn hướng lên trên
            const randomExtraTurns = () => (Math.floor(Math.random() * 3) + 2) * 360;

            const rot1 = faceRotations[v1];
            const rot2 = faceRotations[v2];
            const rot3 = faceRotations[v3];

            d1.style.transform = `rotateX(${rot1.x + randomExtraTurns()}deg) rotateY(${rot1.y + randomExtraTurns()}deg) rotateZ(0deg)`;
            d2.style.transform = `rotateX(${rot2.x + randomExtraTurns()}deg) rotateY(${rot2.y + randomExtraTurns()}deg) rotateZ(0deg)`;
            d3.style.transform = `rotateX(${rot3.x + randomExtraTurns()}deg) rotateY(${rot3.y + randomExtraTurns()}deg) rotateZ(0deg)`;
        }

        // --- HỆ THỐNG KÉO THẢ NẬN BÁT ---
        function initLidDragLogic(finalResult, finalSum, r1, r2, r3) {
            const lid = document.getElementById('stageLid');
            let isDragging = false;
            let startX = 0, startY = 0;
            let currentX = 0, currentY = 0;

            const onStart = (e) => {
                if (gameState !== 'SQUEEZING') return;
                isDragging = true;
                const pageX = e.touches ? e.touches[0].clientX : e.clientX;
                const pageY = e.touches ? e.touches[0].clientY : e.clientY;
                startX = pageX - currentX;
                startY = pageY - currentY;
                lid.style.transition = 'none';
            };

            const onMove = (e) => {
                if (!isDragging) return;
                const pageX = e.touches ? e.touches[0].clientX : e.clientX;
                const pageY = e.touches ? e.touches[0].clientY : e.clientY;
                currentX = pageX - startX;
                currentY = pageY - startY;

                lid.style.transform = `translate(${currentX}px, ${currentY}px)`;

                // Tính toán khoảng cách dịch chuyển nắp nặn
                const distance = Math.sqrt(currentX * currentX + currentY * currentY);
                if (distance > 100) {
                    // Nếu nặn hoặc mở rộng ra xa quá 100px thì nắp bay mất tiêu luôn
                    isDragging = false;
                    lid.style.transition = 'all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1)';
                    lid.style.transform = `translate(${currentX * 2.5}px, ${currentY * 2.5}px)`;
                    lid.style.opacity = '0';
                    
                    document.removeEventListener('mousemove', onMove);
                    document.removeEventListener('mouseup', onEnd);
                    document.removeEventListener('touchmove', onMove);
                    document.removeEventListener('touchend', onEnd);

                    setTimeout(() => { lid.style.display = 'none'; }, 500);
                    triggerResultDeclaration(finalResult, finalSum, r1, r2, r3);
                }
            };

            const onEnd = () => {
                if (!isDragging) return;
                isDragging = false;
                lid.style.transition = 'transform 0.3s ease';
                // Đưa nắp về vị trí trung tâm nếu kéo thả chưa đủ xa
                currentX = 0;
                currentY = 0;
                lid.style.transform = 'translate(0, 0)';
            };

            // Sự kiện chuột máy tính
            lid.addEventListener('mousedown', onStart);
            document.addEventListener('mousemove', onMove);
            document.addEventListener('mouseup', onEnd);

            // Sự kiện cảm ứng điện thoại di động
            lid.addEventListener('touchstart', onStart, { passive: true });
            document.addEventListener('touchmove', onMove, { passive: true });
            document.addEventListener('touchend', onEnd, { passive: true });
        }

        // --- GIAI ĐOẠN 3: TUYÊN BỐ KẾT QUẢ & TRAO THƯỞNG ---
        function triggerResultDeclaration(result, sum, d1, d2, d3) {
            gameState = 'SHOWING';
            document.getElementById('status').textContent = `KẾT QUẢ: ${result} (${sum} ĐIỂM) [${d1}-${d2}-${d3}]`;
            
            // Highlight nháy sáng liên tục cửa thắng cuộc
            const winningBox = (result === 'TÀI') ? document.getElementById('boxTai') : document.getElementById('boxXiu');
            winningBox.classList.add('winning-flash');

            // --- LÔ-GIC TÍNH TOÁN TIỀN PHẠT / THƯỞNG CHUẨN XÁC TUYỆT ĐỐI ---
            let winAmount = 0;
            
            // Đặt cửa nào, ăn cửa đó, thua sạch tiền nếu lệch kết quả
            if (selectedTarget === 'TÀI' && result === 'TÀI') {
                winAmount = myBetTai * 2;
            } else if (selectedTarget === 'XỈU' && result === 'XỈU') {
                winAmount = myBetXiu * 2;
            }

            if (winAmount > 0) {
                // Cộng tiền thắng vào tài khoản của người chơi
                balance += winAmount;
                updateBalanceUI();
                createFloatingWinText(`+ ${formatMoney(winAmount)}đ`);
            } else if (myBetTai > 0 || myBetXiu > 0) {
                // Nếu có đặt tiền nhưng không trùng khớp kết quả -> Thua cược, không được hoàn lại tiền
                createFloatingWinText(`Thua cuộc!`);
            }

            // Đồng bộ lại tất cả giao diện đặt cược về mức 0
            myBetTai = 0;
            myBetXiu = 0;

            // Kiểm tra tình trạng cháy tài khoản (hết tiền)
            setTimeout(() => {
                if (balance <= 0) {
                    showLoseResetScreen();
                } else {
                    // Tiếp tục khởi động vòng chơi tiếp theo tự động sau 7 giây hiển thị kết quả
                    setTimeout(() => {
                        startNewGameLoop();
                    }, 7000);
                }
            }, 1500);
        }

        // --- HIỆU ỨNG CHỮ THẮNG FLOAT BAY LÊN ---
        function createFloatingWinText(text) {
            const container = document.querySelector('.main-stage');
            const floatText = document.createElement('div');
            floatText.className = 'win-animate-text';
            floatText.textContent = text;
            container.appendChild(floatText);

            setTimeout(() => { floatText.remove(); }, 7000);
        }

        // --- HIỂN THỊ MÀN HÌNH RESET TIỀN TỰ ĐỘNG ---
        function showLoseResetScreen() {
            const screen = document.getElementById('loseScreen');
            screen.classList.add('active');
            
            setTimeout(() => {
                balance = 2000000;
                updateBalanceUI();
                screen.classList.remove('active');
                startNewGameLoop();
            }, 5000);
        }

        // --- XỬ LÝ CLICK ĐẶT CỬA TÀI / XỈU ---
        function handleSelectTarget(type) {
            if (gameState !== 'WAITING') return;

            // Chuyển đổi trạng thái highlight viền ngoài vùng chọn
            document.getElementById('boxTai').classList.remove('selected-target');
            document.getElementById('boxXiu').classList.remove('selected-target');

            selectedTarget = type;
            const targetEl = (type === 'TÀI') ? document.getElementById('boxTai') : document.getElementById('boxXiu');
            targetEl.classList.add('selected-target');

            // Tiến hành trừ tiền đặt cược thực tế
            if (balance >= activeChipValue) {
                balance -= activeChipValue;
                if (type === 'TÀI') {
                    myBetTai += activeChipValue;
                    simulatedTotalTai += activeChipValue;
                } else {
                    myBetXiu += activeChipValue;
                    simulatedTotalXiu += activeChipValue;
                }
                updateBalanceUI();
                updateBetsUI();
            } else {
                alert("Số dư khả dụng của bạn không đủ!");
            }
        }

        // --- HỦY TẤT CẢ TIỀN CƯỢC HIỆN TẠI ---
        function cancelAllBets() {
            if (gameState !== 'WAITING') return;
            
            // Trả lại toàn bộ tiền đã đặt về số dư
            balance += (myBetTai + myBetXiu);
            
            simulatedTotalTai -= myBetTai;
            simulatedTotalXiu -= myBetXiu;
            
            myBetTai = 0;
            myBetXiu = 0;
            selectedTarget = null;

            document.getElementById('boxTai').classList.remove('selected-target');
            document.getElementById('boxXiu').classList.remove('selected-target');

            updateBalanceUI();
            updateBetsUI();
        }

        // --- ALL-IN TẤT TAY TOÀN BỘ SỐ TIỀN ---
        function triggerAllIn() {
            if (gameState !== 'WAITING') return;
            if (!selectedTarget) {
                alert("Bạn phải chọn cửa TÀI hoặc XỈU trước khi All-In!");
                return;
            }

            if (balance <= 0) {
                alert("Bạn không còn đủ số dư để đặt cược!");
                return;
            }

            const allInAmount = balance;
            balance = 0;

            if (selectedTarget === 'TÀI') {
                myBetTai += allInAmount;
                simulatedTotalTai += allInAmount;
            } else {
                myBetXiu += allInAmount;
                simulatedTotalXiu += allInAmount;
            }

            updateBalanceUI();
            updateBetsUI();
        }

        // --- LỰA CHỌN CHIP ---
        function selectChip(element, value) {
            document.querySelectorAll('.chip').forEach(el => el.classList.remove('selected'));
            element.classList.add('selected');
            activeChipValue = value;

            // Đồng bộ sang thanh nhập cược tự do
            document.getElementById('customBetInput').value = value;
        }

        function updateCustomBetValue(value) {
            const parsedVal = parseInt(value);
            if (!isNaN(parsedVal) && parsedVal >= 100) {
                activeChipValue = parsedVal;
            }
        }

        function quickBetMultiply(multiplier) {
            const currentVal = parseInt(document.getElementById('customBetInput').value) || 1000;
            let targetVal = Math.floor(currentVal * multiplier);
            if (targetVal < 100) targetVal = 100;
            
            document.getElementById('customBetInput').value = targetVal;
            activeChipValue = targetVal;
        }

        // --- GIẢ LẬP ROBOT ĐẶT TIỀN ẢO TẠO KHÔNG KHÍ SÔI ĐỘNG ---
        function startSimulatingRobotBets() {
            simulatedBetsTimer = setInterval(() => {
                if (gameState !== 'WAITING') return;

                const botBetTai = Math.floor(Math.random() * 25) * 10000;
                const botBetXiu = Math.floor(Math.random() * 25) * 10000;

                simulatedTotalTai += botBetTai;
                simulatedTotalXiu += botBetXiu;

                updateBetsUI();
            }, 800);
        }

        // --- TIỆN ÍCH HOẠT HỌA & ĐỊNH DẠNG ---
        function updateProgressCircle(seconds, total) {
            const circle = document.getElementById('bar');
            const totalDash = 754; // Chu vi vòng tròn bán kính 120
            const progressRatio = seconds / total;
            const offset = totalDash - (progressRatio * totalDash);
            circle.style.strokeDashoffset = offset;
        }

        function updateBalanceUI() {
            document.getElementById('accountBalance').textContent = formatMoney(balance) + "đ";
        }

        function updateBetsUI() {
            document.getElementById('myBetTaiValue').textContent = formatMoney(myBetTai) + "đ";
            document.getElementById('myBetXiuValue').textContent = formatMoney(myBetXiu) + "đ";

            document.getElementById('totalBetTai').textContent = "Tổng: " + formatMoney(simulatedTotalTai) + "đ";
            document.getElementById('totalBetXiu').textContent = "Tổng: " + formatMoney(simulatedTotalXiu) + "đ";
        }

        function formatMoney(num) {
            return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        }

        function virtualDeposit() {
            balance += 2000000;
            updateBalanceUI();
        }

        function openWithdrawModal() {
            alert(`Tính năng đang rút về tài khoản ngân hàng ảo của bạn thành công ${formatMoney(balance)}đ!`);
            balance = 0;
            updateBalanceUI();
            showLoseResetScreen();
        }
    </script>
</body>
</html>
